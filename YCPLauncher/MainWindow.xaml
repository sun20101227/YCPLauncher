<Window x:Class="YCPLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fw="clr-namespace:SourceChord.FluentWPF;assembly=FluentWPF"
        xmlns:local="clr-namespace:YCPLauncher"
        xmlns:helpers="clr-namespace:YCPLauncher.Helpers"
        xmlns:viewmodels="clr-namespace:YCPLauncher.ViewModels"
        xmlns:views="clr-namespace:YCPLauncher.Views"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        mc:Ignorable="d"
        Title="CS2 Launcher"
        Height="720" Width="1080"
        MinHeight="580" MinWidth="860"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="app.ico"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <ContextMenu x:Key="SysTrayMenu" Background="{DynamicResource BgSidebarBrush}" BorderBrush="{DynamicResource BorderBrush1}" BorderThickness="1">
            <ContextMenu.Template>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}" 
                            CornerRadius="6">
                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" Margin="0,4"/>
                    </Border>
                </ControlTemplate>
            </ContextMenu.Template>
            <ContextMenu.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="Padding" Value="16,8"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="MenuItem">
                                <Border x:Name="Border" Background="Transparent" CornerRadius="4" Margin="4,2">
                                    <ContentPresenter ContentSource="Header" Margin="12,6"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ContextMenu.Resources>
            <MenuItem Header="显示面板" Click="TrayShow_Click"/>
            <MenuItem Header="退出 CS2 启动器" Click="TrayExit_Click"/>
        </ContextMenu>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="8" CornerRadius="0" GlassFrameThickness="-1" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <!-- AcrylicWindow needs the background of the root border to be transparent to show the desktop refraction -->
    <Border Background="Transparent" BorderThickness="0">
        <Grid>
            <!-- DYNAMIC BACKGROUND -->
            <Grid ClipToBounds="True">
                <Grid.Background>
                    <SolidColorBrush Color="Transparent"/>
                </Grid.Background>

                <!-- High Quality Background -->
                <Image Source="/Assets/premium_bg.png" Stretch="UniformToFill" RenderTransformOrigin="0.5,0.5">
                    <Image.CacheMode><BitmapCache EnableClearType="False" RenderAtScale="1"/></Image.CacheMode>
                </Image>
                
                <!-- Glass overlay -->
                <Rectangle Fill="{DynamicResource BgOverlayBrush}"/>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="210"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ══════════ SIDEBAR ══════════ -->
                <helpers:RevealBorder Grid.Column="0"
                        Background="{DynamicResource BgSidebarBrush}"
                        CornerRadius="14,0,0,14"
                        HoverColor="#44FF6B00" HoverRadius="300"
                        BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- drag handle -->
                        <RowDefinition Height="Auto"/>  <!-- logo -->
                        <RowDefinition Height="*"/>     <!-- nav -->
                        <RowDefinition Height="Auto"/>  <!-- version & settings -->
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Height="36" Background="Transparent" 
                            MouseLeftButtonDown="DragBorder_MouseLeftButtonDown"
                            Cursor="SizeAll"/>

                    <StackPanel Grid.Row="1" Margin="0,10,0,40" HorizontalAlignment="Center">
                        <Image Source="/Assets/logo.png" Width="64" Height="64" Margin="0,0,0,12" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="YACHIYO CUP" FontSize="18" FontWeight="Black" FontFamily="Arial Black" HorizontalAlignment="Center">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF6B00" Offset="0"/>
                                    <GradientStop Color="#FFA500" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <TextBlock Text="CS2 LAUNCHER" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        <Rectangle Width="30" Height="2" Fill="{DynamicResource BorderBrush2}" Margin="0,16,0,0" Opacity="0.5"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="16,0" x:Name="NavPanel">
                        <!-- Intro Button -->
                        <Button x:Name="NavIntro" Style="{StaticResource NavButton}" 
                                Click="NavIntro_Click" Margin="0,0,0,8"
                                Tag="Intro">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="IntroIndicator" Width="4" Height="20" Background="{DynamicResource AccentBrush}"
                                        HorizontalAlignment="Left" CornerRadius="2" Visibility="Hidden" Margin="-12,0,0,0"/>
                                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8" Background="{DynamicResource AccentBgBrush}">
                                    <TextBlock Text="⭐" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="赛事介绍" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="14" Margin="16,0,0,0"/>
                            </Grid>
                        </Button>

                        <!-- Dashboard Button -->
                        <Button x:Name="NavDashboard" Style="{StaticResource NavButton}" 
                                Click="NavDashboard_Click" Margin="0,0,0,8"
                                Tag="Dashboard">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="DashboardIndicator" Width="4" Height="20" Background="{DynamicResource AccentBrush}"
                                        HorizontalAlignment="Left" CornerRadius="2" Visibility="Hidden" Margin="-12,0,0,0"/>
                                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8" Background="{DynamicResource AccentBgBrush}">
                                    <TextBlock Text="👤" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="选手信息" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="14" Margin="16,0,0,0"/>
                            </Grid>
                        </Button>

                        <!-- Servers Button -->
                        <Button x:Name="NavServers" Style="{StaticResource NavButton}" 
                                Click="NavServers_Click" Margin="0,0,0,8"
                                Tag="Servers">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="ServersIndicator" Width="4" Height="20" Background="{DynamicResource AccentBrush}"
                                        HorizontalAlignment="Left" CornerRadius="2" Visibility="Hidden" Margin="-12,0,0,0"/>
                                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8" Background="{DynamicResource AccentBgBrush}">
                                    <TextBlock Text="🖥" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="游戏服务器" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="14" Margin="16,0,0,0"/>
                            </Grid>
                        </Button>

                        <!-- Live Stream Button -->
                        <Button x:Name="NavLiveStream" Style="{StaticResource NavButton}" 
                                Click="NavLiveStream_Click" Margin="0,0,0,8"
                                Tag="LiveStream">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="LiveStreamIndicator" Width="4" Height="20" Background="{DynamicResource AccentBrush}"
                                        HorizontalAlignment="Left" CornerRadius="2" Visibility="Hidden" Margin="-12,0,0,0"/>
                                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8" Background="{DynamicResource AccentBgBrush}">
                                    <TextBlock Text="🔴" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Effect>
                                            <DropShadowEffect Color="Red" BlurRadius="10" ShadowDepth="0" Opacity="0.8"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                </Border>
                                <TextBlock Grid.Column="1" Text="观看直播" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="14" Margin="16,0,0,0"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="3" Margin="16,20,16,20">
                        <Button x:Name="NavSettings" Style="{StaticResource NavButton}" 
                                Click="NavSettings_Click" Margin="0,0,0,16"
                                Tag="Settings">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="SettingsIndicator" Width="4" Height="20" Background="{DynamicResource AccentBrush}"
                                        HorizontalAlignment="Left" CornerRadius="2" Visibility="Hidden" Margin="-12,0,0,0"/>
                                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8" Background="{DynamicResource AccentBgBrush}">
                                    <TextBlock Text="⚙" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="系统设置" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="14" Margin="16,0,0,0"/>
                            </Grid>
                        </Button>

                        <Border Background="{DynamicResource ItemBgBrush}" CornerRadius="8" Padding="12"
                                BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1">
                            <Grid>
                                <TextBlock Text="1.0.4" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="CS2 EDITION" Foreground="{DynamicResource TextMutedBrush}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.5"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
                </helpers:RevealBorder>

                <!-- ══════════ MAIN CONTENT ══════════ -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="46"/> <!-- Custom Titlebar -->
                        <RowDefinition Height="*"/>  <!-- Page Content -->
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="Transparent" MouseLeftButtonDown="DragBorder_MouseLeftButtonDown">
                        <Grid>
                            <TextBlock Text="基于php和net的CS2社区服启动和管理系统" Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="12" VerticalAlignment="Center" Margin="24,0,0,0"/>
                            
                            <!-- Window Controls -->
                            <StackPanel WindowChrome.IsHitTestVisibleInChrome="True" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0">
                                <Button Style="{StaticResource IconButton}" Click="MinBtn_Click" ToolTip="最小化" Width="36" Height="30">
                                    <TextBlock Text="&#xE921;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Arial" Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/>
                                </Button>
                                <Button x:Name="MaxBtn" Style="{StaticResource IconButton}" Click="MaxBtn_Click" ToolTip="最大化" Width="36" Height="30">
                                    <TextBlock x:Name="MaxIcon" Text="&#xE922;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Arial" Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/>
                                </Button>
                                <Button Style="{StaticResource IconButton}" Click="CloseBtn_Click" ToolTip="关闭" Width="36" Height="30">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#E81123"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Resources>
                                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Arial" Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Page content area -->
                    <Grid Grid.Row="1" Background="Transparent">
                        <ContentControl x:Name="MainContent" Background="Transparent"/>
                        <!-- Toast -->
                        <views:ToastNotification x:Name="Toast"
                                                 VerticalAlignment="Bottom"
                                                 HorizontalAlignment="Center"
                                                 Margin="0,0,0,28"
                                                 Panel.ZIndex="99"/>
                    </Grid>
                </Grid>

            <!-- Tray Icon -->
            <tb:TaskbarIcon x:Name="MyNotifyIcon"
                            IconSource="app.ico"
                            ToolTipText="YCPLauncher"
                            ContextMenu="{StaticResource SysTrayMenu}"
                            TrayMouseDoubleClick="TrayIcon_DoubleClick" />
            </Grid>
        </Grid>
    </Border>
</Window>
