<UserControl x:Class="YCPLauncher.Views.ToastNotification"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Center"
             VerticalAlignment="Bottom"
             IsHitTestVisible="False">
    <Border x:Name="ToastBorder"
            Background="#1A2332"
            BorderBrush="#FF6B00"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16,10"
            Opacity="0">
        <Border.Effect>
            <DropShadowEffect Color="#FF6B00" BlurRadius="16" ShadowDepth="0" Opacity="0.3"/>
        </Border.Effect>
        <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="ToastIcon" Text="✓" Foreground="#FF6B00"
                       FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock x:Name="ToastText" Foreground="White"
                       FontSize="13" FontFamily="Segoe UI" VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>
