<UserControl x:Class="YCPLauncher.Views.LiveStreamView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:fw="clr-namespace:SourceChord.FluentWPF;assembly=FluentWPF"
             xmlns:helpers="clr-namespace:YCPLauncher.Helpers"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1080">
    <UserControl.Resources>
        <!-- Chat Message Template -->
        <DataTemplate x:Key="ChatMessageTemplate">
            <helpers:RevealBorder Margin="0,0,0,12" CornerRadius="8" Padding="12,8" Background="Transparent" HoverColor="#22FFFFFF" HoverRadius="150" BorderThickness="1" BorderBrush="Transparent">
                <helpers:RevealBorder.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.4">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#11FFFFFF" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="4" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="Transparent" Duration="0:0:0.3"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.3"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </helpers:RevealBorder.Triggers>
                <helpers:RevealBorder.RenderTransform>
                    <TranslateTransform X="0" Y="20"/>
                </helpers:RevealBorder.RenderTransform>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Border Width="26" Height="26" CornerRadius="13" Margin="0,0,10,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{DynamicResource AccentColor}" Offset="0"/>
                                    <GradientStop Color="#44FF6B00" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="{Binding Initial}" Foreground="White" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Black"/>
                        </Border>
                        <TextBlock Text="{Binding Username}" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                        <Border Background="#22FFFFFF" CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Time}" Foreground="#999" FontSize="10" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding Message}" Foreground="#EAEAEA" FontSize="13" TextWrapping="Wrap" Margin="36,0,0,0" LineHeight="20"/>
                </StackPanel>
            </helpers:RevealBorder>
        </DataTemplate>
    </UserControl.Resources>

    <!-- Base Page Load Animation (Optimized) -->
    <Grid Background="Transparent">
        <Grid.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <!-- ══ VIDEO PLAYER AREA (WebView2) ══ -->
        <Grid Grid.Column="0" Margin="24">
            <helpers:RevealBorder Style="{StaticResource TileRevealStyle}" CornerRadius="16" ClipToBounds="True" Background="Black">
                <helpers:RevealBorder.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#33FFFFFF" Offset="0"/>
                        <GradientStop Color="#05FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </helpers:RevealBorder.BorderBrush>
                <helpers:RevealBorder.BorderThickness>
                    <Thickness>1</Thickness>
                </helpers:RevealBorder.BorderThickness>

                <Grid>
                    <!-- WebView2 Player -->
                    <wv2:WebView2 x:Name="PlayerWebView" DefaultBackgroundColor="Black"/>
                    
                    <!-- Loading Overlay -->
                    <Border x:Name="LoadingOverlay" Background="Black" Opacity="0.8">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="连接中..." FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="CONNECTING TO ULTRA-LOW LATENCY STREAM" FontSize="12" Foreground="#888" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </helpers:RevealBorder>
        </Grid>

        <!-- ══ CHAT SIDEBAR ══ -->
        <!-- Fixed Background to support glassmorphism -->
        <Border Grid.Column="1" Background="#22000000" BorderBrush="#1AFFFFFF" BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Chat Header -->
                <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="0,0,0,1" Padding="24,20" Background="Transparent">
                    <Grid>
                        <TextBlock Text="实时聊天" Foreground="White" FontSize="18" FontWeight="Black" VerticalAlignment="Center"/>
                        <!-- Animated Giveway Button -->
                        <Button Style="{StaticResource GhostButton}" Content="参与抽奖 ✨" HorizontalAlignment="Right" Padding="16,6" FontSize="13" FontWeight="Bold">
                            <Button.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" x:Name="GiveawayScale"/>
                            </Button.RenderTransform>
                            <Button.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="GiveawayScale" Storyboard.TargetProperty="ScaleX" From="1" To="1.05" Duration="0:0:0.8" AutoReverse="True"/>
                                            <DoubleAnimation Storyboard.TargetName="GiveawayScale" Storyboard.TargetProperty="ScaleY" From="1" To="1.05" Duration="0:0:0.8" AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Button.Triggers>
                        </Button>
                    </Grid>
                </Border>

                <!-- Chat Messages Area -->
                <ScrollViewer Grid.Row="1" x:Name="ChatScroller" VerticalScrollBarVisibility="Auto" Margin="20,16,12,0" Padding="0,0,8,0">
                    <ItemsControl x:Name="ChatList" ItemTemplate="{StaticResource ChatMessageTemplate}"/>
                </ScrollViewer>

                <!-- Chat Input Area -->
                <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="0,1,0,0" Padding="16,16,16,24" Background="Transparent">
                    <!-- Glowing Input Capsule (Integrated Send Button) -->
                    <helpers:RevealBorder CornerRadius="22" BorderThickness="1.5" x:Name="InputContainer" Background="Transparent" 
                            HoverColor="#44FF6B00" HoverRadius="200">
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Perfectly Aligned Placeholder -->
                            <TextBlock Grid.Column="0" Text="发送消息..." Foreground="#888" FontSize="13" VerticalAlignment="Center" Margin="16,0,0,0" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=ChatInput, Path=Text.Length}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            
                            <!-- Pure TextBox without internal padding to avoid cursor misalignment -->
                            <TextBox Grid.Column="0" x:Name="ChatInput" Background="Transparent" BorderThickness="0" Foreground="White" 
                                     VerticalAlignment="Center" Padding="0" Margin="16,0,44,0" FontSize="13"
                                     KeyDown="ChatInput_KeyDown"/>
                            
                            <!-- Integrated Animated Send Button -->
                            <Button Grid.Column="1" Width="34" Height="34" Margin="4" Click="SendButton_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid>
                                            <Border x:Name="Glow" Background="{DynamicResource AccentBrush}" CornerRadius="17" Opacity="0.5">
                                                <Border.Effect>
                                                    <BlurEffect Radius="8"/>
                                                </Border.Effect>
                                            </Border>
                                            <Border x:Name="Bg" Background="{DynamicResource AccentBrush}" CornerRadius="17">
                                                <TextBlock x:Name="Arrow" Text="➤" FontSize="14" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="1,0,0,0"/>
                                            </Border>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2"/>
                                                            <DoubleAnimation Storyboard.TargetName="Arrow" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="3" Duration="0:0:0.2"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity" To="0.5" Duration="0:0:0.3"/>
                                                            <DoubleAnimation Storyboard.TargetName="Arrow" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.3"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Bg" Property="Opacity" Value="0.8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <Button.RenderTransform>
                                    <TranslateTransform X="0"/>
                                </Button.RenderTransform>
                            </Button>
                        </Grid>
                    </helpers:RevealBorder>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
