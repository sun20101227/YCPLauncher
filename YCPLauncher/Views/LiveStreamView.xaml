<UserControl x:Class="YCPLauncher.Views.LiveStreamView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:fw="clr-namespace:SourceChord.FluentWPF;assembly=FluentWPF"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1080">
    <UserControl.Resources>
        <!-- Chat Message Template -->
        <DataTemplate x:Key="ChatMessageTemplate">
            <Border Margin="0,0,0,12" CornerRadius="8" Padding="12,8">
                <!-- Entrance Animation -->
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.4">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#11FFFFFF" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="4" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="Transparent" Duration="0:0:0.3"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.3"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <Border.RenderTransform>
                    <TranslateTransform X="0" Y="20"/>
                </Border.RenderTransform>
                <Border.Background>
                    <SolidColorBrush Color="Transparent"/>
                </Border.Background>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Border Width="26" Height="26" CornerRadius="13" Margin="0,0,10,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{DynamicResource AccentColor}" Offset="0"/>
                                    <GradientStop Color="#44FF6B00" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="{Binding Initial}" Foreground="White" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Black">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1" Opacity="0.5"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </Border>
                        <TextBlock Text="{Binding Username}" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                        <Border Background="#22FFFFFF" CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Time}" Foreground="#999" FontSize="10" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding Message}" Foreground="#EAEAEA" FontSize="13" TextWrapping="Wrap" Margin="36,0,0,0" LineHeight="20"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <!-- Base Page Load Animation -->
    <Grid Background="Transparent">
        <Grid.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.6"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <!-- ══ VIDEO PLAYER AREA ══ -->
        <Grid Grid.Column="0" Margin="24">
            <Border CornerRadius="16" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#111111" Offset="0"/>
                        <GradientStop Color="#050505" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#33FFFFFF" Offset="0"/>
                        <GradientStop Color="#05FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.BorderThickness>
                    <Thickness>1</Thickness>
                </Border.BorderThickness>

                <Grid>
                    <!-- Background Animated Glow -->
                    <Border Margin="100">
                        <Border.Background>
                            <SolidColorBrush Color="{DynamicResource AccentColor}" x:Name="PlayerGlow"/>
                        </Border.Background>
                        <Border.Effect>
                            <BlurEffect Radius="250"/>
                        </Border.Effect>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.05" To="0.15" Duration="0:0:3" AutoReverse="True">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                    </Border>
                    
                    <Rectangle Fill="Black" Opacity="0.5"/>

                    <!-- Sweeping Light Reflection -->
                    <Border Background="#11FFFFFF" Width="100" HorizontalAlignment="Left" RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <TransformGroup>
                                <SkewTransform AngleX="-20"/>
                                <TranslateTransform X="-200" x:Name="SweepTransform"/>
                            </TransformGroup>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="SweepTransform" Storyboard.TargetProperty="X" From="-200" To="1200" Duration="0:0:4" BeginTime="0:0:2">
                                            <DoubleAnimation.EasingFunction>
                                                <ExponentialEase EasingMode="EaseOut" Exponent="2"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                    </Border>
                    
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border x:Name="PlayBtn" Width="80" Height="80" CornerRadius="40" Background="#11FFFFFF" HorizontalAlignment="Center" Margin="0,0,0,24" BorderBrush="#33FFFFFF" BorderThickness="1">
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="1" To="1.05" Duration="0:0:1.5" AutoReverse="True">
                                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="1" To="1.05" Duration="0:0:1.5" AutoReverse="True">
                                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.6" To="1" Duration="0:0:1.5" AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <TextBlock Text="▶" FontSize="42" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </Border>
                        
                        <TextBlock Text="WAITING FOR STREAM SIGNAL..." FontSize="18" FontWeight="Black" Foreground="White" HorizontalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="15" ShadowDepth="0" Opacity="0.6"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="OBS RTMP CONNECTION PENDING" FontSize="11" Foreground="#888" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    </StackPanel>

                    <!-- Top Overlay Bar -->
                    <Grid VerticalAlignment="Top" Margin="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- LIVE Badge -->
                        <Border Grid.Column="0" Background="#E53935" CornerRadius="6" Padding="12,6">
                            <Border.Effect>
                                <DropShadowEffect Color="#E53935" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                            </Border.Effect>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="White" Margin="0,0,8,0">
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.2" Duration="0:0:0.8" AutoReverse="True"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <TextBlock Text="LIVE" Foreground="White" FontWeight="Black" FontSize="13"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Title -->
                        <TextBlock Grid.Column="1" Text="YACHIYO CUP 2026 - GRAND FINALS" Foreground="White" FontSize="18" FontWeight="Black" VerticalAlignment="Center" Margin="20,0">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="4" Opacity="0.8"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        
                        <!-- Viewers -->
                        <Border Grid.Column="2" Background="#88000000" CornerRadius="6" Padding="16,8" BorderBrush="#33FFFFFF" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👁" Foreground="{DynamicResource AccentBrush}" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="5" ShadowDepth="0"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock Text="14,208" Foreground="White" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" FontFamily="Consolas"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ══ CHAT SIDEBAR ══ -->
        <!-- Fixed Background to support glassmorphism -->
        <Border Grid.Column="1" Background="#22000000" BorderBrush="#1AFFFFFF" BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Chat Header -->
                <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="0,0,0,1" Padding="24,20" Background="Transparent">
                    <Grid>
                        <TextBlock Text="实时聊天" Foreground="White" FontSize="18" FontWeight="Black" VerticalAlignment="Center"/>
                        <!-- Animated Giveway Button -->
                        <Button Style="{StaticResource GhostButton}" Content="参与抽奖 ✨" HorizontalAlignment="Right" Padding="16,6" FontSize="13" FontWeight="Bold">
                            <Button.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" x:Name="GiveawayScale"/>
                            </Button.RenderTransform>
                            <Button.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="GiveawayScale" Storyboard.TargetProperty="ScaleX" From="1" To="1.05" Duration="0:0:0.8" AutoReverse="True"/>
                                            <DoubleAnimation Storyboard.TargetName="GiveawayScale" Storyboard.TargetProperty="ScaleY" From="1" To="1.05" Duration="0:0:0.8" AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Button.Triggers>
                        </Button>
                    </Grid>
                </Border>

                <!-- Chat Messages Area -->
                <ScrollViewer Grid.Row="1" x:Name="ChatScroller" VerticalScrollBarVisibility="Auto" Margin="20,16,12,0" Padding="0,0,8,0">
                    <ItemsControl x:Name="ChatList" ItemTemplate="{StaticResource ChatMessageTemplate}"/>
                </ScrollViewer>

                <!-- Chat Input Area -->
                <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="0,1,0,0" Padding="16,16,16,24" Background="Transparent">
                    <!-- Glowing Input Capsule (Integrated Send Button) -->
                    <Border CornerRadius="22" BorderThickness="1.5" x:Name="InputContainer" Background="Transparent" 
                            BorderBrush="{fw:RevealBrush}">
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Perfectly Aligned Placeholder -->
                            <TextBlock Grid.Column="0" Text="发送消息..." Foreground="#888" FontSize="13" VerticalAlignment="Center" Margin="16,0,0,0" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=ChatInput, Path=Text.Length}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            
                            <!-- Pure TextBox without internal padding to avoid cursor misalignment -->
                            <TextBox Grid.Column="0" x:Name="ChatInput" Background="Transparent" BorderThickness="0" Foreground="White" 
                                     VerticalAlignment="Center" Padding="0" Margin="16,0,44,0" FontSize="13"
                                     KeyDown="ChatInput_KeyDown"/>
                            
                            <!-- Integrated Animated Send Button -->
                            <Button Grid.Column="1" Width="34" Height="34" Margin="4" Click="SendButton_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid>
                                            <Border x:Name="Glow" Background="{DynamicResource AccentBrush}" CornerRadius="17" Opacity="0.5">
                                                <Border.Effect>
                                                    <BlurEffect Radius="8"/>
                                                </Border.Effect>
                                            </Border>
                                            <Border x:Name="Bg" Background="{DynamicResource AccentBrush}" CornerRadius="17">
                                                <TextBlock x:Name="Arrow" Text="➤" FontSize="14" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="1,0,0,0"/>
                                            </Border>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2"/>
                                                            <DoubleAnimation Storyboard.TargetName="Arrow" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="3" Duration="0:0:0.2"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity" To="0.5" Duration="0:0:0.3"/>
                                                            <DoubleAnimation Storyboard.TargetName="Arrow" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.3"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Bg" Property="Opacity" Value="0.8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <Button.RenderTransform>
                                    <TranslateTransform X="0"/>
                                </Button.RenderTransform>
                            </Button>
                        </Grid>
                    </Border>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
