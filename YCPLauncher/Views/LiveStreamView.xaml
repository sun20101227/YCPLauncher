<UserControl x:Class="YCPLauncher.Views.LiveStreamView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1080"
             Unloaded="UserControl_Unloaded">

    <Grid Background="Transparent" Margin="24,24,24,8">
        <Grid.RowDefinitions>
            <!-- Video fills all available space -->
            <RowDefinition Height="*"/>
            <!-- Controls bar fixed height -->
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!-- ── Video Border ── -->
        <Border Grid.Row="0" CornerRadius="12,12,0,0" Background="Black"
                BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1,1,1,0">
            <Grid>
                <Grid.OpacityMask>
                    <VisualBrush>
                        <VisualBrush.Visual>
                            <Border Background="Black" CornerRadius="11,11,0,0"
                                    Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Grid}}"
                                    Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Grid}}"/>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Grid.OpacityMask>

                <vlc:VideoView x:Name="VideoPlayer"/>

                <!-- Loading Overlay -->
                <Border x:Name="LoadingOverlay" Background="#CC000000" Visibility="Visible">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="正在连接直播流..." Foreground="White" FontSize="16"
                                   HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <ProgressBar IsIndeterminate="True" Width="220" Height="4"
                                     Foreground="{DynamicResource AccentBrush}"
                                     Background="#33FFFFFF" BorderThickness="0"/>
                        <TextBlock x:Name="TimeoutHint" Text="" Foreground="#88FFFFFF"
                                   FontSize="12" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Failed Overlay -->
                <Border x:Name="FailedOverlay" Background="#CC000000" Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="连接失败" Foreground="White" FontSize="22" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="30 秒内未能建立视频流连接" Foreground="#88FFFFFF"
                                   FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,24"/>
                        <Button x:Name="BtnRetry" Content="重新连接" Width="140" Height="40"
                                Style="{StaticResource OrangeButton}"
                                HorizontalAlignment="Center"
                                Click="BtnRetry_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ── Controls Bar ── -->
        <Border Grid.Row="1" CornerRadius="0,0,12,12" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush2}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#DD0D1117" Offset="0"/>
                    <GradientStop Color="#F2060A0F" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Play/Pause -->
                    <Button x:Name="BtnPlayPause" Width="38" Height="38" Margin="0,0,8,0"
                            Click="BtnPlayPause_Click" Cursor="Hand" ToolTip="播放/暂停">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="10" BorderThickness="1" BorderBrush="#55FF6B00">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#44FF6B00" Offset="0"/>
                                            <GradientStop Color="#22FF6B00" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="BorderBrush" Value="#AAFF6B00"/>
                                        <Setter TargetName="bd" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#FF6B00" BlurRadius="14" ShadowDepth="0" Opacity="0.7"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="bd" Property="BorderBrush" Value="#DDFF6B00"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock x:Name="IconPlayPause" Text="&#xE769;"
                                   FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets,Arial"
                                   FontSize="15" Foreground="#FFCC88"/>
                    </Button>

                    <!-- Refresh -->
                    <Button x:Name="BtnRefresh" Width="34" Height="34"
                            Click="BtnRefresh_Click" Cursor="Hand" ToolTip="重新加载">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd2" CornerRadius="8"
                                        Background="Transparent" BorderThickness="1" BorderBrush="Transparent">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd2" Property="Background" Value="#22FFFFFF"/>
                                        <Setter TargetName="bd2" Property="BorderBrush" Value="#33FFFFFF"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="bd2" Property="Background" Value="#44FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="&#xE72C;"
                                   FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets,Arial"
                                   FontSize="14" Foreground="#88FFFFFF"/>
                    </Button>
                </StackPanel>

                <!-- Divider -->
                <Rectangle Grid.Column="1" Width="1" Height="20" Fill="#22FFFFFF" Margin="12,0"/>

                <!-- Volume -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE767;"
                               FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets,Arial"
                               FontSize="14" Foreground="#66FFFFFF"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Slider x:Name="SldVolume" Minimum="0" Maximum="100" Value="100"
                            Width="100" VerticalAlignment="Center"
                            ValueChanged="SldVolume_ValueChanged">
                        <Slider.Template>
                            <ControlTemplate TargetType="Slider">
                                <Grid>
                                    <Track x:Name="PART_Track">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="Slider.DecreaseLarge">
                                                <RepeatButton.Template>
                                                    <ControlTemplate TargetType="RepeatButton">
                                                        <Border Height="4" CornerRadius="2" Background="#CCFF6B00"/>
                                                    </ControlTemplate>
                                                </RepeatButton.Template>
                                            </RepeatButton>
                                        </Track.DecreaseRepeatButton>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="Slider.IncreaseLarge">
                                                <RepeatButton.Template>
                                                    <ControlTemplate TargetType="RepeatButton">
                                                        <Border Height="4" CornerRadius="2" Background="#33FFFFFF"/>
                                                    </ControlTemplate>
                                                </RepeatButton.Template>
                                            </RepeatButton>
                                        </Track.IncreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Ellipse Fill="#FF6B00" Width="13" Height="13">
                                                            <Ellipse.Effect>
                                                                <DropShadowEffect Color="#FF6B00" BlurRadius="8" ShadowDepth="0" Opacity="0.9"/>
                                                            </Ellipse.Effect>
                                                        </Ellipse>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Slider.Template>
                    </Slider>
                </StackPanel>

                <!-- LIVE Badge -->
                <Border Grid.Column="4" CornerRadius="5" Padding="9,3" VerticalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#CC991100" Offset="0"/>
                            <GradientStop Color="#CCFF3300" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Fill="White" Margin="0,0,5,0" VerticalAlignment="Center">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.15" Duration="0:0:0.7"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <TextBlock Text="LIVE" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
