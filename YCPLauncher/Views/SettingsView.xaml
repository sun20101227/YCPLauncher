<UserControl x:Class="YCPLauncher.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:helpers="clr-namespace:YCPLauncher.Helpers"
             mc:Ignorable="d" 
             Background="Transparent"
             d:DesignHeight="800" d:DesignWidth="800">

    <UserControl.Resources>
        <!-- Animated Toggle Switch Style -->
        <Style x:Key="AnimatedToggleSwitch" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="44" Height="24" Cursor="Hand">
                            <Border x:Name="bgOff" CornerRadius="12" Background="{DynamicResource BorderBrush2}"/>
                            <Border x:Name="bgOn" CornerRadius="12" Background="{DynamicResource AccentBrush}" Opacity="0"/>
                            <Ellipse x:Name="dot" Width="20" Height="20" Fill="White" HorizontalAlignment="Left" Margin="2,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="dot" Storyboard.TargetProperty="Margin" To="22,0,0,0" Duration="0:0:0.2">
                                                <ThicknessAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></ThicknessAnimation.EasingFunction>
                                            </ThicknessAnimation>
                                            <DoubleAnimation Storyboard.TargetName="bgOn" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="dot" Storyboard.TargetProperty="Margin" To="2,0,0,0" Duration="0:0:0.2">
                                                <ThicknessAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></ThicknessAnimation.EasingFunction>
                                            </ThicknessAnimation>
                                            <DoubleAnimation Storyboard.TargetName="bgOn" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="Header" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                    <ThicknessAnimation Storyboard.TargetName="Header" Storyboard.TargetProperty="Margin" From="0,20,0,24" To="0,0,0,24" Duration="0:0:0.4"><ThicknessAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ThicknessAnimation.EasingFunction></ThicknessAnimation>
                    
                    <DoubleAnimation Storyboard.TargetName="Card0" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.1"/>
                    <ThicknessAnimation Storyboard.TargetName="Card0" Storyboard.TargetProperty="Margin" From="0,20,0,24" To="0,0,0,24" Duration="0:0:0.5" BeginTime="0:0:0.1"><ThicknessAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ThicknessAnimation.EasingFunction></ThicknessAnimation>

                    <DoubleAnimation Storyboard.TargetName="Card1" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.2"/>
                    <ThicknessAnimation Storyboard.TargetName="Card1" Storyboard.TargetProperty="Margin" From="0,20,0,24" To="0,0,0,24" Duration="0:0:0.5" BeginTime="0:0:0.2"><ThicknessAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ThicknessAnimation.EasingFunction></ThicknessAnimation>

                    <DoubleAnimation Storyboard.TargetName="Card2" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.3"/>
                    <ThicknessAnimation Storyboard.TargetName="Card2" Storyboard.TargetProperty="Margin" From="0,20,0,24" To="0,0,0,24" Duration="0:0:0.5" BeginTime="0:0:0.3"><ThicknessAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ThicknessAnimation.EasingFunction></ThicknessAnimation>

                    <DoubleAnimation Storyboard.TargetName="Card3" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.4"/>
                    <ThicknessAnimation Storyboard.TargetName="Card3" Storyboard.TargetProperty="Margin" From="0,20,0,24" To="0,0,0,24" Duration="0:0:0.5" BeginTime="0:0:0.4"><ThicknessAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ThicknessAnimation.EasingFunction></ThicknessAnimation>
                    
                    <DoubleAnimation Storyboard.TargetName="CardServer" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.45"/>
                    <ThicknessAnimation Storyboard.TargetName="CardServer" Storyboard.TargetProperty="Margin" From="0,20,0,24" To="0,0,0,24" Duration="0:0:0.5" BeginTime="0:0:0.45"><ThicknessAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ThicknessAnimation.EasingFunction></ThicknessAnimation>
                    
                    <DoubleAnimation Storyboard.TargetName="Card4" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.5"/>
                    <ThicknessAnimation Storyboard.TargetName="Card4" Storyboard.TargetProperty="Margin" From="0,20,0,0" To="0,0,0,0" Duration="0:0:0.5" BeginTime="0:0:0.5"><ThicknessAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ThicknessAnimation.EasingFunction></ThicknessAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  helpers:SmoothScrollViewerBehavior.IsEnabled="True">
        <StackPanel Margin="30,22,30,30">
            <!-- HEADER -->
            <StackPanel x:Name="Header" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,24" Opacity="0">
                <Button Command="{Binding GoBackCommand}" 
                        Visibility="{Binding IsLoggedOut, Converter={StaticResource BoolToVisibility}}"
                        Style="{StaticResource GhostButton}" Margin="0,0,16,0" Padding="8,4" Height="28">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="←" Margin="0,0,4,0"/>
                        <TextBlock Text="返回登录"/>
                    </StackPanel>
                </Button>
                <Rectangle Width="4" Height="22" Fill="{DynamicResource AccentBrush}"
                           RadiusX="2" RadiusY="2" Margin="0,0,12,0"
                           Visibility="{Binding IsLoggedOut, Converter={StaticResource InverseBoolToVisibility}}"/>
                <TextBlock Text="系统设置" FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 账号与安全 -->
            <StackPanel x:Name="Card0" Margin="0,0,0,24" Opacity="0">
                <Border Background="{DynamicResource ItemBgBrush}" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush2}" CornerRadius="12">
                    <StackPanel>
                        <!-- Section Title -->
                        <Border BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="0,0,0,1" Padding="20,15">
                            <TextBlock Text="账号与安全" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Bold" FontSize="14"/>
                        </Border>

                        <Grid Margin="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="修改密码" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                <TextBlock Text="定期修改密码可以保护您的账号安全" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Command="{Binding ChangePasswordCommand}" Content="修改密码" Style="{StaticResource GhostButton}" Height="30" Padding="15,0" Cursor="Hand"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- 常规设置 -->
            <StackPanel x:Name="Card1" Margin="0,0,0,24" Opacity="0">
                <TextBlock Text="外观与行为" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="Bold" Margin="4,0,0,12"/>
                <Border Background="{DynamicResource ItemBgBrush}" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1" CornerRadius="12">
                    <StackPanel>
                        <Grid Margin="20,16">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="深色模式 (Dark Mode)" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                <TextBlock Text="开启后界面将以深色为主，护眼且具电竞感" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding IsDarkMode}" Style="{StaticResource AnimatedToggleSwitch}" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{DynamicResource BorderBrush2}" Margin="20,0"/>
                        <Grid Margin="20,16">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="减轻动画效果" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                <TextBlock Text="关闭部分非必要的 UI 动态缩放和特效以节省性能" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding ReduceAnimations}" Style="{StaticResource AnimatedToggleSwitch}" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{DynamicResource BorderBrush2}" Margin="20,0"/>
                        <Grid Margin="20,16">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="关闭时最小化到托盘" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                <TextBlock Text="开启后点击关闭按钮不会直接退出程序" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding MinimizeToTray}" Style="{StaticResource AnimatedToggleSwitch}" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{DynamicResource BorderBrush2}" Margin="20,0"/>
                        <Grid Margin="20,16">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="开机自动启动" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                <TextBlock Text="随系统启动，随时可以快速进入游戏" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding StartOnBoot}" Style="{StaticResource AnimatedToggleSwitch}" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- CARD 2: Game Launch Parameters -->
            <StackPanel x:Name="Card2" Margin="0,0,0,24" Opacity="0">
                <TextBlock Text="游戏启动参数" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="Bold" Margin="4,0,0,12"/>
                <Border Background="{DynamicResource ItemBgBrush}" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1" CornerRadius="12">
                    <StackPanel>
                        <Grid Margin="20,16">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="跳过启动动画 (-novid)" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                <TextBlock Text="加速游戏加载速度" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding LaunchNoVid}" Style="{StaticResource AnimatedToggleSwitch}" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{DynamicResource BorderBrush2}" Margin="20,0"/>
                        <Grid Margin="20,16">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="高频刷新率 (-freq 240)" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                <TextBlock Text="强制游戏以 240Hz 运行" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding LaunchHighFreq}" Style="{StaticResource AnimatedToggleSwitch}" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{DynamicResource BorderBrush2}" Margin="20,0"/>
                        <Grid Margin="20,16">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="控制台 (-console)" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                <TextBlock Text="在游戏启动时自动打开控制台" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding LaunchConsole}" Style="{StaticResource AnimatedToggleSwitch}" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- CARD 3: Advanced Performance -->
            <StackPanel x:Name="Card3" Margin="0,0,0,24" Opacity="0">
                <TextBlock Text="高级性能" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="Bold" Margin="4,0,0,12"/>
                <Border Background="{DynamicResource ItemBgBrush}" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1" CornerRadius="12">
                    <StackPanel>
                        <Grid Margin="20,16">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="硬件加速渲染 (Hardware Acceleration)" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                <TextBlock Text="利用 GPU 加速 UI 动画，开启极致丝滑体验" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding HardwareAcceleration}" Style="{StaticResource AnimatedToggleSwitch}" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{DynamicResource BorderBrush2}" Margin="20,0"/>
                        <Grid Margin="20,16">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="CS2 启动参数预加载" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                <TextBlock Text="在后台提前挂载启动参数，大幅提升进服速度" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding NetworkOptimization}" Style="{StaticResource AnimatedToggleSwitch}" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- CARD 3.5: Server & Network Configuration -->
            <StackPanel x:Name="CardServer" Margin="0,0,0,24" Opacity="0">
                <TextBlock Text="服务器配置" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="Bold" Margin="4,0,0,12"/>
                <Border Background="{DynamicResource ItemBgBrush}" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1" CornerRadius="12">
                    <StackPanel>
                        <!-- API Base URL -->
                        <Grid Margin="20,16">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,24,0" Width="180">
                                <TextBlock Text="登录与 API 服务器" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                <TextBlock Text="基础服务与玩家数据接口" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            <TextBox Grid.Column="1" Text="{Binding ApiBaseUrl, UpdateSourceTrigger=PropertyChanged}" 
                                     Background="Transparent" Foreground="{DynamicResource TextPrimaryBrush}" 
                                     BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="0,0,0,1" 
                                     VerticalAlignment="Center" Padding="4,8" FontSize="14"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{DynamicResource BorderBrush2}" Margin="20,0"/>

                        <!-- Live Stream URL -->
                        <Grid Margin="20,16">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,24,0" Width="180">
                                <TextBlock Text="RTMP 直播源" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                <TextBlock Text="赛事实况拉流地址" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            <TextBox Grid.Column="1" Text="{Binding LiveStreamUrl, UpdateSourceTrigger=PropertyChanged}" 
                                     Background="Transparent" Foreground="{DynamicResource TextPrimaryBrush}" 
                                     BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="0,0,0,1" 
                                     VerticalAlignment="Center" Padding="4,8" FontSize="14"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{DynamicResource BorderBrush2}" Margin="20,0"/>

                        <!-- Chat URL -->
                        <Grid Margin="20,16">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,24,0" Width="180">
                                <TextBlock Text="聊天室网页地址" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                <TextBlock Text="嵌入的弹幕聊天室 Web 页面" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            <TextBox Grid.Column="1" Text="{Binding ChatUrl, UpdateSourceTrigger=PropertyChanged}" 
                                     Background="Transparent" Foreground="{DynamicResource TextPrimaryBrush}" 
                                     BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="0,0,0,1" 
                                     VerticalAlignment="Center" Padding="4,8" FontSize="14"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- CARD 4: Storage & Uninstall -->
            <StackPanel x:Name="Card4" Opacity="0">
                <TextBlock Text="系统维护" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="Bold" Margin="4,0,0,12"/>
                <Border Background="{DynamicResource ItemBgBrush}" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1" CornerRadius="12">
                    <StackPanel>
                        <!-- ADDED: Check for updates -->
                        <Grid Margin="20,16">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="检查更新" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                <TextBlock Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,4,0,0">
                                    <Run Text="当前版本: "/>
                                    <Run Text="{Binding CurrentVersion, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="1" Command="{Binding CheckUpdateCommand}" Content="检查更新" Style="{StaticResource GhostButton}" Height="30" Padding="15,0" Cursor="Hand"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{DynamicResource BorderBrush2}" Margin="20,0"/>
                        <Grid Margin="20,16">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="清理本地缓存" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                <TextBlock Text="释放图片和临时文件占用的磁盘空间" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Command="{Binding ClearCacheCommand}" Content="一键清理" Style="{StaticResource GhostButton}" Height="30" Padding="15,0" Cursor="Hand"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{DynamicResource BorderBrush2}" Margin="20,0"/>
                        <Grid Margin="20,16">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="卸载 YCP 启动器" Foreground="#EF4444" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="删除所有配置和文件，从本机彻底移除此程序" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Command="{Binding UninstallLauncherCommand}" Content="卸载" Style="{StaticResource GhostButton}" Foreground="#EF4444" BorderBrush="#EF4444" Height="30" Padding="15,0" Cursor="Hand"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
