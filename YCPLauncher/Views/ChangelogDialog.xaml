<Window x:Class="YCPLauncher.Views.ChangelogDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="更新日志" Height="500" Width="600"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" ResizeMode="NoResize">
    <Border CornerRadius="12" Background="#111827" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="更新日志 (Changelog)" Foreground="{StaticResource TextPrimaryBrush}" FontSize="24" FontWeight="Bold" Grid.Row="0"/>
            <TextBlock Text="所有历史版本的更新记录" Foreground="{StaticResource TextMutedBrush}" FontSize="14" Margin="0,5,0,20" Grid.Row="1"/>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,20">
                <StackPanel x:Name="ReleasesPanel">
                    <TextBlock x:Name="TxtLoading" Text="正在加载日志..." Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                </StackPanel>
            </ScrollViewer>

            <Button x:Name="BtnClose" Content="关闭" Grid.Row="3" Style="{StaticResource GhostButton}" Height="40" Click="BtnClose_Click"/>
        </Grid>
    </Border>
</Window>
