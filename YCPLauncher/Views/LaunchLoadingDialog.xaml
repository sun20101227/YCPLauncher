<Window x:Class="YCPLauncher.Views.LaunchLoadingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="正在启动..." Height="200" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" Topmost="True" ShowInTaskbar="False">
    <Border Background="{DynamicResource BgDeepBrush}" CornerRadius="16" BorderBrush="{DynamicResource BorderBrush1}" BorderThickness="1" Margin="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" Color="{DynamicResource ShadowColor}" Opacity="0.5" ShadowDepth="10"/>
        </Border.Effect>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- Spinner -->
            <Grid Width="40" Height="40" Margin="0,0,0,16">
                <Grid.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Grid.Triggers>
                <Grid.RenderTransform>
                    <RotateTransform Angle="0" CenterX="20" CenterY="20"/>
                </Grid.RenderTransform>
                <Path Data="M 20 2 A 18 18 0 0 1 38 20" Stroke="{DynamicResource AccentBrush}" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Path Data="M 38 20 A 18 18 0 0 1 20 38" Stroke="{DynamicResource BorderBrush1}" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Path Data="M 20 38 A 18 18 0 0 1 2 20" Stroke="{DynamicResource BorderBrush1}" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Path Data="M 2 20 A 18 18 0 0 1 20 2" Stroke="{DynamicResource BorderBrush1}" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
            </Grid>
            
            <TextBlock Text="正在启动游戏..." FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="请耐心等待，通常需要 5 - 15 秒..." FontSize="13" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
