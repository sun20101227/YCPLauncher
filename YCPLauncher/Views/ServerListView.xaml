<UserControl x:Class="YCPLauncher.Views.ServerListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:helpers="clr-namespace:YCPLauncher.Helpers"
             mc:Ignorable="d"
             Background="Transparent">

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <!-- Perfectly centered spin animation -->
            <BeginStoryboard x:Name="PingSpinStoryboard">
                <Storyboard x:Name="PingSpinAnim" RepeatBehavior="Forever">
                    <DoubleAnimation Storyboard.TargetName="PingRotate" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:1" AutoReverse="False"/>
                </Storyboard>
            </BeginStoryboard>
            
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="Header" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                    <ThicknessAnimation Storyboard.TargetName="Header" Storyboard.TargetProperty="Margin" From="0,20,0,0" To="0,0,0,0" Duration="0:0:0.4"><ThicknessAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ThicknessAnimation.EasingFunction></ThicknessAnimation>
                    
                    <DoubleAnimation Storyboard.TargetName="StatusBar" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.1"/>
                    
                    <DoubleAnimation Storyboard.TargetName="ContentArea" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.2"/>
                    <ThicknessAnimation Storyboard.TargetName="ContentArea" Storyboard.TargetProperty="Margin" From="30,20,30,20" To="30,0,30,20" Duration="0:0:0.5" BeginTime="0:0:0.2"><ThicknessAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ThicknessAnimation.EasingFunction></ThicknessAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header -->
            <RowDefinition Height="Auto"/>  <!-- legend + status bar -->
            <RowDefinition Height="*"/>     <!-- best server card / loading / empty -->
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══════════════════════════════════════════════════ -->
        <Border x:Name="Header" Grid.Row="0" Padding="30,22,30,0" Opacity="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Rectangle Width="4" Height="22" Fill="{DynamicResource AccentBrush}" RadiusX="2" RadiusY="2" Margin="0,0,12,0">
                        <Rectangle.Effect>
                            <DropShadowEffect Color="#FF6B00" BlurRadius="10" ShadowDepth="0"/>
                        </Rectangle.Effect>
                    </Rectangle>
                    <TextBlock Text="最佳游戏服务器" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <Border Background="{DynamicResource ItemBgBrush}" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1"
                            CornerRadius="12" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Foreground="{DynamicResource SuccessBrush}" FontSize="11" FontWeight="Bold" Text="智能推荐延迟最低"/>
                    </Border>
                </StackPanel>

                <!-- Action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Command="{Binding RefreshPingCommand}" Style="{StaticResource GhostButton}" Margin="0,0,8,0" Padding="12,7">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center">
                                <Grid Width="24" Height="24">
                                    <Path Data="M12,2 A10,10 0 1,0 22,12 A10,10 0 0,0 12,2 M12,4 A8,8 0 1,1 4,12 A8,8 0 0,1 12,4 M12,6 L16,9 L12,12 Z" Fill="{DynamicResource TextMutedBrush}">
                                        <Path.RenderTransform>
                                            <RotateTransform x:Name="PingRotate" CenterX="12" CenterY="12"/>
                                        </Path.RenderTransform>
                                    </Path>
                                </Grid>
                            </Viewbox>
                            <TextBlock Text="测速并刷新" FontSize="12" VerticalAlignment="Center" Margin="0,0,0,2"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ STATUS BAR ══════════════════════════════════════════════ -->
        <Border x:Name="StatusBar" Grid.Row="1" Padding="30,14,30,14" Opacity="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Ping legend -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="LegendDot1" Width="7" Height="7" Fill="{DynamicResource SuccessBrush}" VerticalAlignment="Center" Margin="0,0,5,0">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.3" Duration="0:0:1.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <TextBlock Text="极低 &lt;50ms" Foreground="{DynamicResource TextDimBrush}" FontSize="11" Margin="0,0,18,0"/>
                    
                    <Ellipse Width="7" Height="7" Fill="{DynamicResource WarningBrush}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="中等 50-120ms" Foreground="{DynamicResource TextDimBrush}" FontSize="11" Margin="0,0,18,0"/>
                    
                    <Ellipse Width="7" Height="7" Fill="{DynamicResource ErrorBrush}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="较高 &gt;120ms" Foreground="{DynamicResource TextDimBrush}" FontSize="11"/>
                </StackPanel>

                <!-- Last updated -->
                <TextBlock Grid.Column="1" Text="{Binding LastUpdated}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ══ CONTENT ══════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="2" Margin="30,0,30,20" Opacity="0" x:Name="ContentArea" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <!-- LOADING SPINNER -->
                <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" HorizontalAlignment="Center" Margin="0,40,0,0">
                    <Grid Width="56" Height="56" Margin="0,0,0,20">
                        <Ellipse Width="56" Height="56" Stroke="{DynamicResource BorderBrush1}" StrokeThickness="4" Fill="Transparent"/>
                        <Ellipse Width="56" Height="56" Stroke="{DynamicResource AccentBrush}" StrokeThickness="4" Fill="Transparent" StrokeDashArray="22 50" RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform x:Name="SpinnerRotate"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="SpinnerRotate" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.9"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                    </Grid>
                    <TextBlock Text="正在寻找服务器..." Foreground="{DynamicResource TextMutedBrush}" FontSize="13" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- ERROR BANNER -->
                <Border Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}" Background="{DynamicResource ItemBgBrush}" BorderBrush="{DynamicResource ErrorBrush}" BorderThickness="1" CornerRadius="10" Padding="18,14" Margin="0,40,0,0" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠" Foreground="{DynamicResource ErrorBrush}" FontSize="16" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel>
                            <TextBlock Text="加载失败" Foreground="{DynamicResource ErrorBrush}" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" Margin="0,3,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- EMPTY STATE -->
                <StackPanel Margin="0,40,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsLoading}" Value="False"/>
                                        <Condition Binding="{Binding HasError}"  Value="False"/>
                                        <Condition Binding="{Binding HasBestServer}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Border Width="80" Height="80" CornerRadius="40" Background="{DynamicResource ItemBgBrush}" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1" Margin="0,0,0,16" HorizontalAlignment="Center">
                        <TextBlock Text="🖥" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="暂无可用服务器" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" HorizontalAlignment="Center"/>
                    <TextBlock Text="请稍后点击「测速并刷新」重试" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>


                <!-- SERVER LIST -->
                <ItemsControl ItemsSource="{Binding Servers}" Margin="0,10,0,0" Padding="8">
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoading}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <helpers:RevealBorder Style="{StaticResource TileRevealStyle}"
                                                  Margin="0,0,0,16"
                                                  Padding="20"
                                                  CornerRadius="12"
                                                  BorderThickness="1"
                                                  Cursor="Hand">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Server Info (Name & IP) -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,0">
                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="18" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="{DynamicResource ItemBgBrush}" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1" CornerRadius="6" Padding="6,2" Margin="0,0,10,0">
                                                <TextBlock Text="{Binding Location, StringFormat='📍 {0}'}" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                            </Border>
                                            <TextBlock Foreground="{DynamicResource TextDimBrush}" FontSize="12" FontFamily="Consolas" VerticalAlignment="Center">
                                                <Run Text="{Binding Ip}"/>
                                                <Run Text=":"/>
                                                <Run Text="{Binding Port}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Players -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,24,0">
                                        <TextBlock Text="当前人数" Foreground="{DynamicResource TextDimBrush}" FontSize="11" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                                        <TextBlock Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold" FontFamily="Consolas" HorizontalAlignment="Center">
                                            <Run Text="{Binding Players}"/>
                                            <Run Text="/" Foreground="{DynamicResource TextMutedBrush}"/>
                                            <Run Text="{Binding MaxPlayers}" Foreground="{DynamicResource TextMutedBrush}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Ping -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,24,0">
                                        <TextBlock Text="延迟" Foreground="{DynamicResource TextDimBrush}" FontSize="11" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Ellipse Width="8" Height="8" Margin="0,0,6,0" Fill="{Binding Ping, Converter={StaticResource PingToColor}}">
                                                <Ellipse.Effect>
                                                    <DropShadowEffect Color="{Binding Ping, Converter={StaticResource PingToColor}, ConverterParameter=color}" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
                                                </Ellipse.Effect>
                                            </Ellipse>
                                            <TextBlock Text="{Binding Ping, Converter={StaticResource PingToText}}" FontSize="14" FontFamily="Consolas" FontWeight="Bold" Foreground="{Binding Ping, Converter={StaticResource PingToColor}}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Actions -->
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Style="{StaticResource GhostButton}" Margin="0,0,12,0" Height="40" Width="40"
                                                CommandParameter="{Binding}"
                                                Command="{Binding DataContext.CopyIpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                ToolTip="复制 IP">
                                            <TextBlock Text="📋" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Button>
                                        <Button Style="{StaticResource OrangeButton}" Height="40" Padding="16,0"
                                                CommandParameter="{Binding}"
                                                Command="{Binding DataContext.JoinServerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="▶" FontSize="12" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="连接" Foreground="White" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </helpers:RevealBorder>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
