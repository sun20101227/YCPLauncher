<UserControl x:Class="YCPLauncher.Views.LobbyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1080"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Compact player row -->
        <DataTemplate x:Key="PlayerSlotTemplate">
            <Grid Margin="0,0,0,5" MinHeight="44">
                <!-- Left accent line when IsMe -->
                <Border Width="3" HorizontalAlignment="Left" CornerRadius="2">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMe}" Value="True">
                                    <Setter Property="Background" Value="#FF6B00"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
                <!-- Slot background -->
                <Border Margin="6,0,0,0" CornerRadius="6">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#0DFFFFFF"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMe}" Value="True">
                                    <Setter Property="Background" Value="#12FF6B00"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid Margin="10,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Name -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Visibility="{Binding IsOccupied, Converter={StaticResource BoolToVis}}"
                                       VerticalAlignment="Center"/>
                            <Border Background="#33FF6B00" BorderBrush="#88FF6B00" BorderThickness="1" CornerRadius="4" Padding="4,0" Margin="8,0,0,0" VerticalAlignment="Center"
                                    Visibility="{Binding IsMe, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="YOU" FontSize="9" FontWeight="Black" Foreground="#FF9955"/>
                            </Border>
                            <TextBlock Text="— 空位" FontSize="12" Foreground="#404050"
                                       Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <!-- Right -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,2,0">
                            <Border CornerRadius="3" Background="#22AAFFAA" Padding="6,2" Margin="0,0,8,0"
                                    Visibility="{Binding IsReady, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="准备" FontSize="11" Foreground="#88FF88" FontWeight="Bold"/>
                            </Border>
                            <Button Content="加入" Width="52" Height="30"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding DataContext.JoinSlotCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- Coach row (slightly different tint) -->
        <DataTemplate x:Key="CoachSlotTemplate">
            <Grid Margin="0,4,0,0" MinHeight="42">
                <Border Width="3" HorizontalAlignment="Left" CornerRadius="2">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMe}" Value="True">
                                    <Setter Property="Background" Value="#FF6B00"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
                <Border Margin="6,0,0,0" CornerRadius="6" Background="#0AFFA500">
                    <Grid Margin="10,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="教练" FontSize="10" FontWeight="Bold"
                                   Foreground="#CC7700" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Visibility="{Binding IsOccupied, Converter={StaticResource BoolToVis}}"
                                       VerticalAlignment="Center"/>
                            <Border Background="#33FF6B00" BorderBrush="#88FF6B00" BorderThickness="1" CornerRadius="4" Padding="4,0" Margin="8,0,0,0" VerticalAlignment="Center"
                                    Visibility="{Binding IsMe, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="YOU" FontSize="9" FontWeight="Black" Foreground="#FF9955"/>
                            </Border>
                            <TextBlock Text="— 空位" FontSize="12" Foreground="#404050"
                                       Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,2,0">
                            <Border CornerRadius="3" Background="#22AAFFAA" Padding="6,2" Margin="0,0,8,0"
                                    Visibility="{Binding IsReady, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="准备" FontSize="11" Foreground="#88FF88" FontWeight="Bold"/>
                            </Border>
                            <Button Content="加入" Width="52" Height="30"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding DataContext.JoinSlotCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- Spectator row (right panel) -->
        <DataTemplate x:Key="SpectatorRowTemplate">
            <Grid Margin="0,0,0,4" MinHeight="40">
                <Border Width="3" HorizontalAlignment="Left" CornerRadius="2">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMe}" Value="True">
                                    <Setter Property="Background" Value="#FF6B00"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
                <Border Margin="6,0,0,0" CornerRadius="6" Background="#08FFFFFF">
                    <Grid Margin="10,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Visibility="{Binding IsOccupied, Converter={StaticResource BoolToVis}}"
                                       VerticalAlignment="Center"/>
                            <Border Background="#33FF6B00" BorderBrush="#88FF6B00" BorderThickness="1" CornerRadius="4" Padding="4,0" Margin="8,0,0,0" VerticalAlignment="Center"
                                    Visibility="{Binding IsMe, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="YOU" FontSize="9" FontWeight="Black" Foreground="#FF9955"/>
                            </Border>
                            <TextBlock Text="— 空位" FontSize="12" Foreground="#404050"
                                       Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="加入" Width="52" Height="30"
                                Style="{StaticResource GhostButton}"
                                Command="{Binding DataContext.JoinSlotCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"/>
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>

        <Storyboard x:Key="ShakeAnimation">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)">
                <EasingDoubleKeyFrame KeyTime="0:0:0.00" Value="-8"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.05" Value="8"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.10" Value="-8"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.15" Value="8"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.20" Value="-4"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="4"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.30" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>

    <!-- Outer container to anchor everything -->
    <Grid>
        
        <!-- ════════ ENTRY MODE (Create / Join Screen) ════════ -->
        <Grid Visibility="{Binding IsInEntryMode, Converter={StaticResource BoolToVis}}">
            <Border Background="#B20A0B12" CornerRadius="16" BorderBrush="#1AFFFFFF" BorderThickness="1" 
                    HorizontalAlignment="Center" VerticalAlignment="Center" Padding="40,30,40,40">
                <StackPanel Width="440">
                    <!-- Title -->
                    <TextBlock Text="匹配竞技 / 房间大厅" FontSize="26" FontWeight="Black" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="与朋友一起进行内部对抗赛" FontSize="14" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,0,0,32"/>

                    <!-- Error / Status message (if any) -->
                    <TextBlock Text="{Binding LobbyStatus}" FontSize="14" FontWeight="Bold" Foreground="#FF5555" HorizontalAlignment="Center" Margin="0,0,0,4"
                               Visibility="{Binding LobbyStatus, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding LobbySubStatus}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,0,0,16"
                               Visibility="{Binding LobbySubStatus, Converter={StaticResource BoolToVis}}"/>

                    <!-- Create Room -->
                    <Border Background="#12FFFFFF" CornerRadius="12" BorderBrush="#1AFFFFFF" BorderThickness="1" Padding="24" Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="新建一个房间" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock Text="创建后您将获得一个 6 位数的房间码，发给朋友即可加入房间。" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,0,0,16"/>
                            <Button Height="40" Command="{Binding CreateNewRoomCommand}" IsEnabled="{Binding CanJoinOrCreate}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource OrangeButton}">
                                        <Setter Property="Content" Value="创建新房间"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCreatingRoom}" Value="True">
                                                <Setter Property="Content" Value="正在创建..."/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Join Room -->
                    <Border Background="#12FFFFFF" CornerRadius="12" BorderBrush="#1AFFFFFF" BorderThickness="1" Padding="24">
                        <StackPanel>
                            <TextBlock Text="加入朋友的房间" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock Text="向创建房间的朋友索要 6 位数房间码并在此输入。" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,0,0,16"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <!-- Custom TextBox container -->
                                <Border x:Name="RoomCodeBorder" Width="140" Height="40" Background="#1AFFFFFF" BorderThickness="1" CornerRadius="8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="#44FFFFFF"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRoomCodeInvalid}" Value="True">
                                                    <Setter Property="BorderBrush" Value="#FF5555"/>
                                                    <Setter Property="Background" Value="#22FF0000"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.RenderTransform>
                                        <TranslateTransform X="0" Y="0"/>
                                    </Border.RenderTransform>
                                    <TextBox Text="{Binding RoomCodeInput, UpdateSourceTrigger=PropertyChanged}" 
                                             FontSize="20" FontWeight="Black" Foreground="{DynamicResource TextPrimaryBrush}"
                                             Background="Transparent" BorderThickness="0"
                                             VerticalAlignment="Center" HorizontalContentAlignment="Center" TextAlignment="Center" Padding="0,2,0,0"
                                             CharacterCasing="Upper" MaxLength="6" IsEnabled="{Binding CanJoinOrCreate}"/>
                                </Border>
                                
                                <Button Width="110" Height="40" Margin="12,0,0,0" Command="{Binding JoinByCodeCommand}" IsEnabled="{Binding CanJoinOrCreate}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource OrangeButton}">
                                            <Setter Property="Content" Value="加入房间"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsJoiningRoom}" Value="True">
                                                    <Setter Property="Content" Value="正在加入..."/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ════════ ROOM MODE (Actual Lobby) ════════ -->
        <DockPanel Margin="28,20,28,20" Visibility="{Binding IsInRoomMode, Converter={StaticResource BoolToVis}}">

            <!-- Header -->
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="4" Height="20" Fill="{DynamicResource AccentBrush}" RadiusX="2" RadiusY="2" Margin="0,0,10,0">
                                <Rectangle.Effect>
                                    <DropShadowEffect Color="#FF6B00" BlurRadius="8" ShadowDepth="0"/>
                                </Rectangle.Effect>
                            </Rectangle>
                            <TextBlock Text="匹配竞技 / 房间大厅" FontSize="18" FontWeight="Black" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <TextBlock Text="全员准备后主席点击开始游戏。教练/观战需后端支持。"
                                   Foreground="#505060" Margin="14,5,0,0" FontSize="12"/>
                    </StackPanel>

                    <!-- Display Room Code at top right -->
                    <Border Grid.Column="1" Background="#20000000" BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="8" Padding="12,6" VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="房间码 " FontSize="12" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding DisplayRoomCode}" FontSize="18" FontWeight="Black" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <Button Content="{Binding CopyStatusText}" Width="50" Height="22" Margin="10,0,0,0" Padding="0" FontSize="11"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding CopyRoomCodeCommand}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <!-- Action Bar (Rounded Box at bottom) -->
            <Border DockPanel.Dock="Bottom" Margin="0,14,0,0" CornerRadius="12"
                    Background="{DynamicResource CardBgBrush}"
                    BorderThickness="1" BorderBrush="{DynamicResource BorderBrush2}"
                    Padding="20,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding LobbyStatus}" FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding LobbySubStatus}" FontSize="12"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,3,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="解散 / 离开房间" Width="110" Height="36" Margin="0,0,10,0"
                            Style="{StaticResource GhostButton}" Foreground="#FFA0A0"
                            Command="{Binding LeaveRoomCommand}"/>
                    <Button Grid.Column="2" Content="退出位置" Width="90" Height="36" Margin="0,0,10,0"
                            Style="{StaticResource GhostButton}" Foreground="{DynamicResource TextMutedBrush}"
                            Command="{Binding LeaveSlotCommand}"
                            Visibility="{Binding HasJoined, Converter={StaticResource BoolToVis}}"/>
                    <Button Grid.Column="3" Content="已准备" Width="120" Height="36" Margin="0,0,10,0"
                            Style="{StaticResource OrangeButton}" Background="#3A6FAF"
                            Command="{Binding ReadyCommand}"
                            Visibility="{Binding CanReady, Converter={StaticResource BoolToVis}}"/>
                    <Button Grid.Column="4" Content="开始游戏" Width="140" Height="36"
                            Style="{StaticResource OrangeButton}"
                            Command="{Binding StartGameCommand}"
                            IsEnabled="{Binding CanStartGame}"/>
                </Grid>
            </Border>

            <!-- Main 3-column content -->
            <Border Background="#E605050A" CornerRadius="12" BorderBrush="#1AFFFFFF" BorderThickness="1" Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>   <!-- CT -->
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>   <!-- T -->
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="240"/> <!-- Spectators fixed width -->
                        </Grid.ColumnDefinitions>

                        <!-- ── CT Column ── -->
                        <StackPanel Grid.Column="0">
                            <!-- Team label -->
                            <StackPanel Orientation="Horizontal" Margin="6,0,0,8">
                                <TextBlock Text="反恐精英" FontSize="13" FontWeight="Bold" Foreground="#5B9BD5"/>
                                <TextBlock Text=" CT" FontSize="13" FontWeight="Bold" Foreground="#3A6FAF"/>
                                <TextBlock Text="{Binding CtCountText}" FontSize="11" Foreground="#404060"
                                           VerticalAlignment="Bottom" Margin="6,0,0,2"/>
                            </StackPanel>
                            <!-- 5 player slots -->
                            <ItemsControl ItemsSource="{Binding CtSlots}" ItemTemplate="{StaticResource PlayerSlotTemplate}"/>
                            <!-- Thin separator -->
                            <Rectangle Height="1" Fill="#15FFFFFF" Margin="6,6,0,0"/>
                            <!-- Coach -->
                            <ContentPresenter Content="{Binding CoachCTSlot}" ContentTemplate="{StaticResource CoachSlotTemplate}"/>
                        </StackPanel>

                        <!-- ── T Column ── -->
                        <StackPanel Grid.Column="2">
                            <StackPanel Orientation="Horizontal" Margin="6,0,0,8">
                                <TextBlock Text="恐怖分子" FontSize="13" FontWeight="Bold" Foreground="#ED7D31"/>
                                <TextBlock Text=" T" FontSize="13" FontWeight="Bold" Foreground="#B85A10"/>
                                <TextBlock Text="{Binding TCountText}" FontSize="11" Foreground="#504030"
                                           VerticalAlignment="Bottom" Margin="6,0,0,2"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding TSlots}" ItemTemplate="{StaticResource PlayerSlotTemplate}"/>
                            <Rectangle Height="1" Fill="#15FFFFFF" Margin="6,6,0,0"/>
                            <ContentPresenter Content="{Binding CoachTSlot}" ContentTemplate="{StaticResource CoachSlotTemplate}"/>
                        </StackPanel>

                        <!-- ── Spectator / Host Column ── -->
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="主席 / 观战" FontSize="13" FontWeight="Bold" Foreground="#707080"
                                       Margin="6,0,0,8"/>
                            <!-- Host (主席) -->
                            <TextBlock Text="主席" FontSize="10" Foreground="#505060" Margin="6,0,0,3"/>
                            <ContentPresenter Content="{Binding HostSlot}" ContentTemplate="{StaticResource SpectatorRowTemplate}"/>
                            <!-- Spectator slots (visual, pending backend support) -->
                            <Rectangle Height="1" Fill="#12FFFFFF" Margin="6,8,0,8"/>
                            <TextBlock Text="观战  （开发中）" FontSize="10" Foreground="#404050" Margin="6,0,0,4"/>
                            <Grid Opacity="0.4">
                                <Grid.IsHitTestVisible>False</Grid.IsHitTestVisible>
                                <StackPanel>
                                    <!-- 5 placeholder spectator rows -->
                                    <Border Height="38" Margin="6,0,0,4" CornerRadius="5" Background="#08FFFFFF">
                                        <TextBlock Text="— 空位" FontSize="12" Foreground="#303040" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Height="38" Margin="6,0,0,4" CornerRadius="5" Background="#08FFFFFF">
                                        <TextBlock Text="— 空位" FontSize="12" Foreground="#303040" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Height="38" Margin="6,0,0,4" CornerRadius="5" Background="#08FFFFFF">
                                        <TextBlock Text="— 空位" FontSize="12" Foreground="#303040" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Height="38" Margin="6,0,0,4" CornerRadius="5" Background="#08FFFFFF">
                                        <TextBlock Text="— 空位" FontSize="12" Foreground="#303040" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Height="38" Margin="6,0,0,0" CornerRadius="5" Background="#08FFFFFF">
                                        <TextBlock Text="— 空位" FontSize="12" Foreground="#303040" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>

        </DockPanel>

    </Grid>
</UserControl>
