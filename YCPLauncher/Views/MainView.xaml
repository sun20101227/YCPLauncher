<UserControl x:Class="YCPLauncher.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:helpers="clr-namespace:YCPLauncher.Helpers"
             mc:Ignorable="d"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="Header" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                    <ThicknessAnimation Storyboard.TargetName="Header" Storyboard.TargetProperty="Margin" From="0,40,0,24" To="0,0,0,24" Duration="0:0:0.6"><ThicknessAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.5"/></ThicknessAnimation.EasingFunction></ThicknessAnimation>
                    
                    <DoubleAnimation Storyboard.TargetName="Row1" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5" BeginTime="0:0:0.1"/>
                    <ThicknessAnimation Storyboard.TargetName="Row1" Storyboard.TargetProperty="Margin" From="0,40,0,20" To="0,0,0,20" Duration="0:0:0.7" BeginTime="0:0:0.1"><ThicknessAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.5"/></ThicknessAnimation.EasingFunction></ThicknessAnimation>

                    <DoubleAnimation Storyboard.TargetName="Row2" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5" BeginTime="0:0:0.2"/>
                    <ThicknessAnimation Storyboard.TargetName="Row2" Storyboard.TargetProperty="Margin" From="0,40,0,20" To="0,0,0,20" Duration="0:0:0.7" BeginTime="0:0:0.2"><ThicknessAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.5"/></ThicknessAnimation.EasingFunction></ThicknessAnimation>
                    
                    <DoubleAnimation Storyboard.TargetName="Row3" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5" BeginTime="0:0:0.3"/>
                    <ThicknessAnimation Storyboard.TargetName="Row3" Storyboard.TargetProperty="Margin" From="0,40,0,0" To="0,0,0,0" Duration="0:0:0.7" BeginTime="0:0:0.3"><ThicknessAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.5"/></ThicknessAnimation.EasingFunction></ThicknessAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="30,22,30,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- header -->
                <RowDefinition Height="Auto"/>  <!-- profile & stats row -->
                <RowDefinition Height="Auto"/>  <!-- news & matches row -->
                <RowDefinition Height="Auto"/>  <!-- missions & live row -->
            </Grid.RowDefinitions>

            <!-- ══ HEADER ══════════════════════════════════════════════════ -->
            <Grid x:Name="Header" Grid.Row="0" Margin="0,0,0,24" Opacity="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Rectangle Width="4" Height="22" Fill="{DynamicResource AccentBrush}" RadiusX="2" RadiusY="2" Margin="0,0,12,0">
                        <Rectangle.Effect>
                            <DropShadowEffect Color="#FF6B00" BlurRadius="10" ShadowDepth="0"/>
                        </Rectangle.Effect>
                    </Rectangle>
                    <TextBlock Text="控制面板" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"
                               FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="1" Command="{Binding LogoutCommand}"
                        Style="{StaticResource GhostButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⇥" FontSize="14" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="退出登录" FontSize="12" FontFamily="Segoe UI" Foreground="{DynamicResource TextMutedBrush}"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- ══ ROW 1: PROFILE & STATS ═════════════════════════════════ -->
            <Grid x:Name="Row1" Grid.Row="1" Margin="0,0,0,20" Opacity="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.5*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <!-- Profile Card -->
                <helpers:RevealBorder Grid.Column="0" Margin="0,0,20,0" Style="{StaticResource TileRevealStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Player Identity -->
                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" Width="80" Height="80" CornerRadius="12"
                                    Background="{DynamicResource ItemBgBrush}" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1"
                                    Margin="0,0,16,0">
                                <TextBlock Text="🛡" FontSize="40" Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Player.DisplayName}"
                                           FontSize="24" FontWeight="Black" FontFamily="Segoe UI Black"
                                           Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <Border Background="{DynamicResource AccentBgBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                        <TextBlock Text="{Binding Player.TeamShort}"
                                                   Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold"
                                                   FontFamily="Segoe UI"/>
                                    </Border>
                                    <TextBlock Text="{Binding Player.Username, StringFormat='@{0}'}"
                                               Foreground="{DynamicResource TextMutedBrush}" FontSize="12" FontFamily="Segoe UI"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- Identity Details -->
                        <StackPanel Grid.Row="1">
                            <TextBlock Text="STEAM ID" Foreground="{DynamicResource TextDimBrush}" FontSize="10" FontFamily="Segoe UI" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding Player.SteamId}" Foreground="{DynamicResource TextMutedBrush}" FontSize="13" FontFamily="Consolas" Margin="0,0,0,12"/>
                            
                            <TextBlock Text="战队全称" Foreground="{DynamicResource TextDimBrush}" FontSize="10" FontFamily="Segoe UI" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding Player.TeamName}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontFamily="Segoe UI" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </helpers:RevealBorder>

                <!-- Stats Card -->
                <helpers:RevealBorder Grid.Column="1" Style="{StaticResource TileRevealStyle}">
                    <StackPanel>
                        <TextBlock Text="生涯数据统计 (本赛季)" Foreground="{DynamicResource TextDimBrush}" FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,16"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Stat 1 -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="RATING 2.0" Foreground="{DynamicResource TextDimBrush}" FontSize="10" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding StatRating}" Foreground="{DynamicResource SuccessBrush}" FontSize="20" FontWeight="Black" FontFamily="Consolas"/>
                                <ProgressBar Value="{Binding BarRating}" Maximum="100" Height="4" Margin="0,10,20,0"
                                             Background="{DynamicResource BorderBrush1}" Foreground="{DynamicResource SuccessBrush}" BorderThickness="0"/>
                            </StackPanel>

                            <!-- Stat 2 -->
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="K/D RATIO" Foreground="{DynamicResource TextDimBrush}" FontSize="10" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding StatKd}" Foreground="{DynamicResource AccentBrush}" FontSize="20" FontWeight="Black" FontFamily="Consolas"/>
                                <ProgressBar Value="{Binding BarKd}" Maximum="100" Height="4" Margin="0,10,20,0"
                                             Background="{DynamicResource BorderBrush1}" Foreground="{DynamicResource AccentBrush}" BorderThickness="0"/>
                            </StackPanel>

                            <!-- Stat 3 -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="爆头率" Foreground="{DynamicResource TextDimBrush}" FontSize="10" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding StatHs}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="20" FontWeight="Black" FontFamily="Consolas"/>
                                <ProgressBar Value="{Binding BarHs}" Maximum="100" Height="4" Margin="0,10,20,0"
                                             Background="{DynamicResource BorderBrush1}" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0"/>
                            </StackPanel>

                            <!-- Stat 4 -->
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="总场次" Foreground="{DynamicResource TextDimBrush}" FontSize="10" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding StatMatches}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="20" FontWeight="Black" FontFamily="Consolas"/>
                                <!-- Fake graph -->
                                <Path Data="M 0,10 L 10,8 L 20,12 L 30,5 L 40,9 L 50,2" Stroke="{DynamicResource TextMutedBrush}" StrokeThickness="2" Margin="0,10,20,0" Stretch="Fill" Height="14"/>
                            </StackPanel>
                        </Grid>

                        <Rectangle Height="1" Fill="{DynamicResource BorderBrush2}" Margin="0,20"/>
                        
                        <Button Command="{Binding JoinMatchCommand}"
                                Height="40" Style="{StaticResource OrangeButton}">
                            <!-- Pulse Animation for button content -->
                            <Button.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.7" Duration="0:0:1.5"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Button.Triggers>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="▶" FontSize="12" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="自动进入对局" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </helpers:RevealBorder>
            </Grid>

            <!-- ══ ROW 2: NEWS & MATCHES ═════════════════════════════════ -->
            <Grid x:Name="Row2" Grid.Row="2" Margin="0,0,0,20" Opacity="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Recent Matches -->
                <helpers:RevealBorder Grid.Column="0" Margin="0,0,20,0" Style="{StaticResource TileRevealStyle}">
                    <StackPanel>
                        <TextBlock Text="近期战绩" Foreground="{DynamicResource TextDimBrush}" FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,16"/>
                        
                        <ItemsControl ItemsSource="{Binding RecentMatches}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource ItemBgBrush}" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1"
                                            CornerRadius="8" Padding="14,10" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Result badge -->
                                            <Border Grid.Column="0" Width="40" Height="24" CornerRadius="4" Margin="0,0,12,0"
                                                    VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#1A22C55E"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Result}" Value="LOSS">
                                                                <Setter Property="Background" Value="#1AEF4444"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Result}" FontSize="10" FontWeight="Bold" FontFamily="Segoe UI" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Result}" Value="LOSS">
                                                                    <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>

                                            <!-- Info -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding MapName}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                                <TextBlock Text="{Binding Date}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10" FontFamily="Segoe UI" Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- Score -->
                                            <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Score}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="Bold" FontFamily="Consolas" HorizontalAlignment="Right"/>
                                                <TextBlock Foreground="{DynamicResource TextDimBrush}" FontSize="10" FontFamily="Consolas" HorizontalAlignment="Right" Margin="0,2,0,0">
                                                    <Run Text="K/D "/>
                                                    <Run Text="{Binding Kd}" Foreground="{DynamicResource TextMutedBrush}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </helpers:RevealBorder>

                <!-- News / Banners -->
                <helpers:RevealBorder Grid.Column="1" Style="{StaticResource TileRevealStyle}">
                    <StackPanel>
                        <TextBlock Text="赛事新闻" Foreground="{DynamicResource TextDimBrush}" FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,16"/>
                        
                        <!-- Glowing Animated Banner -->
                        <Border x:Name="NewsBanner" Height="140" CornerRadius="8" Background="{DynamicResource ItemBgBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" Margin="0,0,0,12" ClipToBounds="True">
                            <Grid>
                                <Rectangle Fill="{DynamicResource AccentBrush}" Opacity="0.1"/>
                                <Ellipse Width="150" Height="150" Fill="{DynamicResource AccentBrush}" Opacity="0.2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-40,-40">
                                    <Ellipse.Effect>
                                        <BlurEffect Radius="40"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <StackPanel VerticalAlignment="Bottom" Margin="16">
                                    <Border Background="{DynamicResource AccentBrush}" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" Margin="0,0,0,6">
                                        <TextBlock Text="{Binding NewsBanner.Tag}" Foreground="White" FontSize="10" FontWeight="Bold" FontFamily="Segoe UI"/>
                                    </Border>
                                    <TextBlock Text="{Binding NewsBanner.Title}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="Bold" FontFamily="Segoe UI"/>
                                    <TextBlock Text="{Binding NewsBanner.Subtitle}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" FontFamily="Segoe UI" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Height="80" CornerRadius="8" Background="{DynamicResource ItemBgBrush}" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1">
                            <Grid Margin="16">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding NewsAnnouncement.Title}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                    <TextBlock Text="{Binding NewsAnnouncement.Content}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" FontFamily="Segoe UI" Margin="0,4,0,0"/>
                                </StackPanel>
                                <TextBlock Text="📢" FontSize="20" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform x:Name="SpeakerIcon"/>
                                    </TextBlock.RenderTransform>
                                    <TextBlock.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                    <DoubleAnimation Storyboard.TargetName="SpeakerIcon" Storyboard.TargetProperty="Angle" From="-10" To="10" Duration="0:0:0.5"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </TextBlock.Triggers>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </StackPanel>
                </helpers:RevealBorder>
            </Grid>

            <!-- ══ ROW 3: MISSIONS & LIVE ═════════════════════════════════ -->
            <Grid x:Name="Row3" Grid.Row="3" Opacity="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Daily Missions -->
                <helpers:RevealBorder Grid.Column="0" Margin="0,0,20,0" Style="{StaticResource TileRevealStyle}">
                    <StackPanel>
                        <TextBlock Text="每日电竞任务" Foreground="{DynamicResource TextDimBrush}" FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,16"/>
                        <ItemsControl ItemsSource="{Binding DailyMissions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0" Margin="0,0,0,4">
                                            <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontFamily="Segoe UI"/>
                                            <TextBlock Text="{Binding ProgressText}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" FontFamily="Consolas" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <Border Grid.Row="1" Height="6" CornerRadius="3" Background="{DynamicResource BorderBrush1}">
                                            <Border CornerRadius="3" Background="{DynamicResource AccentBrush}" HorizontalAlignment="Left" Width="{Binding ProgressPercent, ConverterParameter=2.5}">
                                                <!-- A small glowing effect inside the progress bar -->
                                                <Border.Effect><DropShadowEffect Color="#FF6B00" BlurRadius="5" ShadowDepth="0"/></Border.Effect>
                                            </Border>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </helpers:RevealBorder>

                <!-- Live Esports Matches -->
                <helpers:RevealBorder Grid.Column="1" Style="{StaticResource TileRevealStyle}">
                    <StackPanel>
                        <TextBlock Text="近期顶级赛事" Foreground="{DynamicResource TextDimBrush}" FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,16"/>
                        <ItemsControl ItemsSource="{Binding LiveMatches}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource ItemBgBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,8" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Team 1 -->
                                            <TextBlock Grid.Column="0" Text="{Binding Team1}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="Bold" FontFamily="Segoe UI" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                            
                                            <!-- Score/Status -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding Score}" Foreground="{DynamicResource SuccessBrush}" FontSize="14" FontWeight="Black" FontFamily="Consolas" HorizontalAlignment="Center">
                                                    <!-- Pulse Animation for Live Text -->
                                                    <TextBlock.Triggers>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.5" Duration="0:0:1"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </TextBlock.Triggers>
                                                </TextBlock>
                                                <TextBlock Text="{Binding EventName}" Foreground="{DynamicResource TextMutedBrush}" FontSize="9" FontFamily="Segoe UI" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            
                                            <!-- Team 2 -->
                                            <TextBlock Grid.Column="2" Text="{Binding Team2}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="Bold" FontFamily="Segoe UI" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </helpers:RevealBorder>
            </Grid>
        </Grid>
    </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Background="#99000000" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Width="40" Height="40" Margin="0,0,0,16">
                    <Path Data="M20,4 A16,16 0 1,0 36,20 A16,16 0 0,0 20,4 M20,8 A12,12 0 1,1 8,20 A12,12 0 0,1 20,8 M20,10 L26,14 L20,18 Z" Fill="{DynamicResource AccentBrush}" RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <RotateTransform x:Name="LoadingSpinner"/>
                        </Path.RenderTransform>
                        <Path.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="LoadingSpinner" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Path.Triggers>
                    </Path>
                </Grid>
                <TextBlock Text="正在同步数据..." Foreground="{DynamicResource TextMutedBrush}" FontSize="13" FontFamily="Segoe UI" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
