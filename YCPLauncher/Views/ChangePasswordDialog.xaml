<Window x:Class="YCPLauncher.Views.ChangePasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="修改密码" Width="400" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" ResizeMode="NoResize"
        Closing="Window_Closing">
    <Border CornerRadius="12" Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="5" Opacity="0.5"/>
        </Border.Effect>
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="修改密码" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="20" FontWeight="Bold" Grid.Row="0"/>
            
            <!-- Close Button -->
            <Button Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" 
                    Width="30" Height="30" Padding="0" Margin="0,-10,-10,0"
                    Style="{StaticResource GhostButton}" Click="BtnCancel_Click" Cursor="Hand">
                <Path Data="M 5,5 L 15,15 M 15,5 L 5,15" Stroke="{DynamicResource TextMutedBrush}" StrokeThickness="2" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>

            <StackPanel Grid.Row="1" Margin="0,20,0,0">
                <TextBlock Text="原密码" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,0,0,8"/>
                <Border Height="44" Background="{DynamicResource ItemBgBrush}" CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush1}">
                    <PasswordBox x:Name="TxtOldPassword" Style="{x:Null}" Background="Transparent" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0" Padding="12,0" FontSize="14" CaretBrush="{DynamicResource TextPrimaryBrush}" VerticalContentAlignment="Center"/>
                </Border>

                <TextBlock Text="新密码" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,20,0,8"/>
                <Border Height="44" Background="{DynamicResource ItemBgBrush}" CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush1}">
                    <PasswordBox x:Name="TxtNewPassword" Style="{x:Null}" Background="Transparent" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0" Padding="12,0" FontSize="14" CaretBrush="{DynamicResource TextPrimaryBrush}" VerticalContentAlignment="Center"/>
                </Border>

                <TextBlock x:Name="TxtError" Foreground="#EF4444" FontSize="12" Margin="0,15,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="取消" Style="{StaticResource GhostButton}" Height="36" Width="80" Margin="0,0,10,0" Click="BtnCancel_Click" Cursor="Hand"/>
                <Button x:Name="BtnConfirm" Content="确认修改" Style="{StaticResource OrangeButton}" Height="36" Width="100" Click="BtnConfirm_Click" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
