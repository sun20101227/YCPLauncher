<Page x:Class="YCPLauncher.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="Transparent"
      Title="登录">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Center Panel -->
        <Border Grid.Row="1"
                Width="420"
                Background="#0D1117"
                BorderBrush="#FF6B00"
                BorderThickness="1"
                CornerRadius="12"
                Padding="40">
            <Border.Effect>
                <DropShadowEffect Color="#FF6B00" BlurRadius="40" ShadowDepth="0" Opacity="0.25"/>
            </Border.Effect>

            <StackPanel>
                <!-- Logo / Title -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,32">
                    <TextBlock Text="Y  C  P"
                               FontSize="40"
                               FontWeight="Black"
                               FontFamily="Segoe UI Black"
                               Foreground="#FF6B00"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="L  A  U  N  C  H  E  R"
                               FontSize="13"
                               FontWeight="SemiBold"
                               FontFamily="Segoe UI"
                               Foreground="#8B9AB0"
                               HorizontalAlignment="Center"/>
                    <!-- Divider -->
                    <Rectangle Height="2" Fill="#FF6B00" Opacity="0.6" Margin="0,12,0,0" Width="80" HorizontalAlignment="Center">
                        <Rectangle.Effect>
                            <DropShadowEffect Color="#FF6B00" BlurRadius="8" ShadowDepth="0"/>
                        </Rectangle.Effect>
                    </Rectangle>
                </StackPanel>

                <!-- Username -->
                <TextBlock Text="账号" Foreground="#8B9AB0" FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                <Border Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="6" Margin="0,0,0,16">
                    <Grid>
                        <TextBlock Text="&#xF787;" FontFamily="Segoe MDL2 Assets" Foreground="#8B9AB0"
                                   VerticalAlignment="Center" Margin="12,0,0,0" FontSize="14"/>
                        <TextBox x:Name="UsernameBox"
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent"
                                 Foreground="White"
                                 CaretBrush="White"
                                 BorderThickness="0"
                                 Padding="36,12,12,12"
                                 FontSize="14"
                                 FontFamily="Segoe UI"
                                 VerticalContentAlignment="Center"
                                 KeyDown="Input_KeyDown"/>
                    </Grid>
                </Border>

                <!-- Password -->
                <TextBlock Text="密码" Foreground="#8B9AB0" FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                <Border Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="6" Margin="0,0,0,24">
                    <Grid>
                        <TextBlock Text="&#xF83D;" FontFamily="Segoe MDL2 Assets" Foreground="#8B9AB0"
                                   VerticalAlignment="Center" Margin="12,0,0,0" FontSize="14"/>
                        <PasswordBox x:Name="PasswordBox"
                                     Background="Transparent"
                                     Foreground="White"
                                     CaretBrush="White"
                                     BorderThickness="0"
                                     Padding="36,12,12,12"
                                     FontSize="14"
                                     FontFamily="Segoe UI"
                                     VerticalContentAlignment="Center"
                                     KeyDown="Password_KeyDown"/>
                    </Grid>
                </Border>

                <!-- Error Message -->
                <Border Background="#2D1515" BorderBrush="#FF4444" BorderThickness="1" CornerRadius="6"
                        Padding="12,10" Margin="0,0,0,16"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠  " Foreground="#FF4444" FontSize="13"/>
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF6666" FontSize="13" FontFamily="Segoe UI" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Login Button -->
                <Button Command="{Binding LoginCommand}"
                        Height="44"
                        FontSize="15"
                        FontWeight="SemiBold"
                        FontFamily="Segoe UI"
                        Cursor="Hand"
                        Style="{StaticResource OrangeButton}">
                    <Grid>
                        <TextBlock Text="登 录" Foreground="White"
                                   Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibility}}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="正在登录..." Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Button>

            </StackPanel>
        </Border>

        <!-- Bottom Version -->
        <TextBlock Grid.Row="2" Text="YCPLauncher v1  |  CS2 电竞启动器"
                   Foreground="#3D4855" FontSize="11" FontFamily="Segoe UI"
                   HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,16"/>
    </Grid>
</Page>
