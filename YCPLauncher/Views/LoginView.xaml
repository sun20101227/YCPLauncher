<UserControl x:Class="YCPLauncher.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:helpers="clr-namespace:YCPLauncher.Helpers"
             mc:Ignorable="d"
             Background="Transparent">

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="LoginCard" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.6"/>
                    <ThicknessAnimation Storyboard.TargetName="LoginCard" Storyboard.TargetProperty="Margin" From="0,60,0,0" To="0,0,0,0" Duration="0:0:0.8">
                        <ThicknessAnimation.EasingFunction>
                            <BackEase EasingMode="EaseOut" Amplitude="0.6"/>
                        </ThicknessAnimation.EasingFunction>
                    </ThicknessAnimation>
                    <DoubleAnimation Storyboard.TargetName="LoginCardScale" Storyboard.TargetProperty="ScaleX" From="0.95" To="1" Duration="0:0:0.8">
                        <DoubleAnimation.EasingFunction>
                            <BackEase EasingMode="EaseOut" Amplitude="0.6"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="LoginCardScale" Storyboard.TargetProperty="ScaleY" From="0.95" To="1" Duration="0:0:0.8">
                        <DoubleAnimation.EasingFunction>
                            <BackEase EasingMode="EaseOut" Amplitude="0.6"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <helpers:RevealBorder x:Name="LoginCard" Grid.Row="1"
                Width="480"
                Background="{DynamicResource CardBgBrush}"
                HoverColor="#22FF6B00"
                HoverRadius="400"
                BorderBrush="{DynamicResource BorderBrush2}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="54,48"
                RenderTransformOrigin="0.5,0.5">
            <helpers:RevealBorder.RenderTransform>
                <ScaleTransform x:Name="LoginCardScale" ScaleX="1" ScaleY="1"/>
            </helpers:RevealBorder.RenderTransform>
            <helpers:RevealBorder.Effect>
                <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="80" ShadowDepth="0" Opacity="0.4"/>
            </helpers:RevealBorder.Effect>

            <StackPanel>
                <!-- Logo -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,36">
                    <Image Source="/Assets/logo.png" Width="80" Height="80" Margin="0,0,0,16" RenderOptions.BitmapScalingMode="HighQuality">
                        <Image.Effect>
                            <DropShadowEffect Color="#FF6B00" BlurRadius="20" ShadowDepth="0" Opacity="0.4"/>
                        </Image.Effect>
                    </Image>
                    <TextBlock Text="YACHIYO CUP" FontSize="28" FontWeight="Black"
                               FontFamily="Segoe UI Black" Foreground="{DynamicResource AccentBrush}"
                               HorizontalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FF6B00" BlurRadius="15" ShadowDepth="0" Opacity="0.6"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="CS2 LAUNCHER" FontSize="12" FontWeight="SemiBold"
                               FontFamily="Segoe UI" Foreground="{DynamicResource TextMutedBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    <Rectangle Height="2" Width="60" Fill="{DynamicResource AccentBrush}" HorizontalAlignment="Center"
                               Margin="0,14,0,0" Opacity="0.8">
                        <Rectangle.Effect>
                            <DropShadowEffect Color="#FF6B00" BlurRadius="6" ShadowDepth="0"/>
                        </Rectangle.Effect>
                    </Rectangle>
                </StackPanel>

                <!-- Username field -->
                <TextBlock Text="账号" Foreground="{DynamicResource TextDimBrush}" FontSize="14" FontWeight="SemiBold"
                           FontFamily="Segoe UI" Margin="0,0,0,10"/>
                <helpers:RevealBorder x:Name="UserBorder" Background="{DynamicResource ItemBgBrush}" HoverColor="#44FF6B00" HoverRadius="200" BorderBrush="{DynamicResource BorderBrush2}"
                        BorderThickness="1" CornerRadius="8" Margin="0,0,0,24" Height="50">
                    <Grid>
                        <TextBlock Text="👤" FontSize="18" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16,0,0,0"/>
                        <TextBox x:Name="UsernameBox"
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" Foreground="{DynamicResource TextPrimaryBrush}" CaretBrush="{DynamicResource AccentBrush}"
                                 BorderThickness="0" Margin="46,0,16,0"
                                 FontSize="16" FontFamily="Segoe UI"
                                 VerticalAlignment="Center"
                                 KeyDown="Input_KeyDown"
                                 GotFocus="Field_GotFocus" LostFocus="Field_LostFocus"/>
                    </Grid>
                </helpers:RevealBorder>

                <!-- Password field -->
                <TextBlock Text="密码" Foreground="{DynamicResource TextDimBrush}" FontSize="14" FontWeight="SemiBold"
                           FontFamily="Segoe UI" Margin="0,0,0,10"/>
                <helpers:RevealBorder x:Name="PassBorder" Background="{DynamicResource ItemBgBrush}" HoverColor="#44FF6B00" HoverRadius="200" BorderBrush="{DynamicResource BorderBrush2}"
                        BorderThickness="1" CornerRadius="8" Margin="0,0,0,32" Height="50">
                    <Grid>
                        <TextBlock Text="🔒" FontSize="18" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16,0,0,0"/>
                        <PasswordBox x:Name="PasswordBox"
                                     Background="Transparent" Foreground="{DynamicResource TextPrimaryBrush}" CaretBrush="{DynamicResource AccentBrush}"
                                     BorderThickness="0" Margin="46,0,16,0"
                                     FontSize="16" FontFamily="Segoe UI"
                                     VerticalAlignment="Center"
                                     KeyDown="Input_KeyDown"
                                     PasswordChanged="PasswordBox_PasswordChanged"
                                     GotFocus="Field_GotFocus" LostFocus="Field_LostFocus"/>
                    </Grid>
                </helpers:RevealBorder>

                <!-- Error Message -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource ErrorBrush}" FontSize="12"
                           FontFamily="Segoe UI" Margin="0,0,0,12" HorizontalAlignment="Center"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityInverse}}"/>

                <!-- Login Button -->
                <Button x:Name="LoginBtn" Command="{Binding LoginCommand}"
                        Style="{StaticResource OrangeButton}"
                        Height="54" Margin="0,0,0,16">
                    <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibility}}">
                            <TextBlock Text="登 录" FontSize="16" FontWeight="Black" Margin="0,0,8,0"/>
                            <TextBlock Text="→" FontSize="18" FontFamily="Consolas" VerticalAlignment="Center"/>
                        </StackPanel>
                        <!-- Loading spinner -->
                        <Path x:Name="SpinnerIcon" Data="M 12 2 A 10 10 0 1 1 2 12"
                              Stroke="White" StrokeThickness="3" StrokeEndLineCap="Round" StrokeStartLineCap="Round"
                              Width="24" Height="24" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                              RenderTransformOrigin="0.5,0.5">
                            <Path.RenderTransform>
                                <RotateTransform x:Name="RotateTrans"/>
                            </Path.RenderTransform>
                            <Path.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="RotateTrans" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.8"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Path.Triggers>
                        </Path>
                    </Grid>
                </Button>
            </StackPanel>
        </helpers:RevealBorder>
    </Grid>
</UserControl>
