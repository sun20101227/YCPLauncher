<Page x:Class="YCPLauncher.Views.ServerListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:YCPLauncher.Converters"
      xmlns:helpers="clr-namespace:YCPLauncher.Helpers"
      mc:Ignorable="d"
      Background="Transparent">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Rectangle Width="4" Height="28" Fill="#FF6B00" RadiusX="2" RadiusY="2" Margin="0,0,12,0">
                    <Rectangle.Effect>
                        <DropShadowEffect Color="#FF6B00" BlurRadius="8" ShadowDepth="0"/>
                    </Rectangle.Effect>
                </Rectangle>
                <TextBlock Text="游戏服务器" FontSize="22" FontWeight="Bold" Foreground="White" FontFamily="Segoe UI" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Refresh -->
            <Button Grid.Column="1"
                    Command="{Binding LoadServersCommand}"
                    Style="{StaticResource GhostButton}"
                    Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="↻  " Foreground="#8B9AB0" FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock Text="刷新" Foreground="#8B9AB0" FontSize="13" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Ping Legend -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <Ellipse Width="8" Height="8" Fill="#4CAF50" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBlock Text="极低 &lt;50ms" Foreground="#8B9AB0" FontSize="12" FontFamily="Segoe UI" Margin="0,0,16,0"/>
            <Ellipse Width="8" Height="8" Fill="#FFB300" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBlock Text="一般 50-120ms" Foreground="#8B9AB0" FontSize="12" FontFamily="Segoe UI" Margin="0,0,16,0"/>
            <Ellipse Width="8" Height="8" Fill="#F44336" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBlock Text="较高 &gt;120ms" Foreground="#8B9AB0" FontSize="12" FontFamily="Segoe UI"/>
        </StackPanel>

        <!-- Loading -->
        <Border Grid.Row="2" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="正在加载服务器..." Foreground="#8B9AB0" FontSize="16" FontFamily="Segoe UI" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Error -->
        <Border Grid.Row="2" Background="#2D1515" BorderBrush="#FF4444" BorderThickness="1" CornerRadius="8"
                Padding="16" VerticalAlignment="Top"
                Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF6666" FontSize="14" FontFamily="Segoe UI"/>
        </Border>

        <!-- Server List -->
        <ScrollViewer Grid.Row="2"
                      Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibility}}"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Servers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <helpers:RevealBorder Style="{StaticResource TileRevealStyle}"
                                Padding="20,16"
                                Margin="0,0,0,12"
                                Tag="{Binding}">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Name & Address -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="White"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               FontFamily="Segoe UI"/>
                                    <TextBlock FontSize="13" Foreground="#8B9AB0" FontFamily="Consolas" Margin="0,4,0,0">
                                        <Run Text="{Binding Ip}"/>
                                        <Run Text=":"/>
                                        <Run Text="{Binding Port}"/>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Location -->
                                <Border Grid.Column="1"
                                        Background="#1A2332"
                                        BorderBrush="#2A3A4A"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10,6"
                                        Margin="12,0,12,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Location}"
                                               Foreground="#A0B0C0"
                                               FontSize="13"
                                               FontFamily="Segoe UI"/>
                                </Border>

                                <!-- Ping -->
                                <Border Grid.Column="2"
                                        Background="#0A1520"
                                        BorderBrush="#1E2D3D"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="12,6"
                                        Margin="0,0,16,0"
                                        VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0"
                                                 Fill="{Binding Ping, Converter={StaticResource PingToColor}}"/>
                                        <TextBlock FontSize="14" FontFamily="Consolas" FontWeight="SemiBold"
                                                   Foreground="{Binding Ping, Converter={StaticResource PingToColor}}">
                                            <Run Text="{Binding Ping}"/>
                                            <Run Text="ms"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- Join Button -->
                                <Button Grid.Column="3"
                                        Content="进入服务器"
                                        CommandParameter="{Binding}"
                                        Command="{Binding DataContext.JoinServerCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        Height="38"
                                        Width="110"
                                        Style="{StaticResource OrangeButton}"
                                        FontSize="13"
                                        Cursor="Hand"/>
                            </Grid>
                        </helpers:RevealBorder>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
