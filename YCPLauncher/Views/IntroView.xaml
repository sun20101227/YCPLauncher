<UserControl x:Class="YCPLauncher.Views.IntroView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:helpers="clr-namespace:YCPLauncher.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>
        <Style TargetType="TextBlock" x:Key="TitleStyle">
            <Setter Property="FontFamily" Value="HarmonyOS Sans SC, MiSans, PingFang SC, Microsoft YaHei UI, Arial Black, sans-serif"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="StatNumberStyle">
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI, sans-serif"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="2,0,2,0"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="StatLabelStyle">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Overlay for full glass effect over the content area -->
        <Border Background="#44000000" CornerRadius="8" Margin="24"/>
        
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="24">
            <StackPanel Margin="32">
                <!-- HERO SECTION -->
                <helpers:RevealBorder Style="{StaticResource TileRevealStyle}" CornerRadius="20" Margin="0,0,0,48" Padding="48">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Icon/Badge -->
                        <Border Width="72" Height="72" Background="{DynamicResource AccentBgBrush}" CornerRadius="20" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <Image Source="/Assets/logo.png" Width="48" Height="48" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                        
                        <TextBlock Text="EPT Masters" Foreground="{DynamicResource AccentBrush}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" />
                        
                        <TextBlock Text="YACHIYO CUP" Style="{StaticResource TitleStyle}" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,8,0,0">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="15" ShadowDepth="0" Opacity="0.6"/>
                            </TextBlock.Effect>
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FFFF6B00" Offset="0"/>
                                    <GradientStop Color="#FFFFD500" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                        
                        <TextBlock Text="VALORANT FRIENDSHIP TOURNAMENT" Foreground="{DynamicResource TextMutedBrush}" FontSize="15" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    </StackPanel>
                </helpers:RevealBorder>

                <!-- STATS ROW -->
                <Grid Margin="0,0,0,48">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <helpers:RevealBorder Grid.Column="0" Style="{StaticResource TileRevealStyle}" CornerRadius="16" Padding="32,24">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="4" Style="{StaticResource StatNumberStyle}" HorizontalAlignment="Center"/>
                            <TextBlock Text="参赛战队" Style="{StaticResource StatLabelStyle}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </helpers:RevealBorder>

                    <helpers:RevealBorder Grid.Column="2" Style="{StaticResource TileRevealStyle}" CornerRadius="16" Padding="32,24">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="600,000" Style="{StaticResource StatNumberStyle}" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="赛事总奖池 (VND)" Style="{StaticResource StatLabelStyle}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </helpers:RevealBorder>

                    <helpers:RevealBorder Grid.Column="4" Style="{StaticResource TileRevealStyle}" CornerRadius="16" Padding="32,24">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="DongGuan" Style="{StaticResource StatNumberStyle}" HorizontalAlignment="Center"/>
                            <TextBlock Text="比赛地点" Style="{StaticResource StatLabelStyle}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </helpers:RevealBorder>
                </Grid>

                <Rectangle Height="1" Fill="{DynamicResource BorderBrush2}" Margin="0,0,0,48"/>

                <!-- TEAMS SECTION -->
                <TextBlock Text="参赛战队" Style="{StaticResource TitleStyle}" FontSize="24" Margin="0,0,0,24"/>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- DL Gaming -->
                    <helpers:RevealBorder Grid.Column="0" Style="{StaticResource TileRevealStyle}" HoverColor="#44FF6B00" HoverRadius="200" Background="{DynamicResource ItemBgBrush}" CornerRadius="16" Padding="24,32">
                        <StackPanel>
                            <Border Width="64" Height="64" CornerRadius="32" Background="#44D40511" BorderBrush="#D40511" BorderThickness="2" HorizontalAlignment="Center" Margin="0,0,0,20">
                                <TextBlock Text="DL" Foreground="#FFD40511" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="DL Gaming" Foreground="White" FontSize="17" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock Text="线上直邀" Foreground="{DynamicResource TextMutedBrush}" FontSize="13" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </helpers:RevealBorder>

                    <!-- JH Gaming -->
                    <helpers:RevealBorder Grid.Column="2" Style="{StaticResource TileRevealStyle}" HoverColor="#44FF6B00" HoverRadius="200" Background="{DynamicResource ItemBgBrush}" CornerRadius="16" Padding="24,32">
                        <StackPanel>
                            <Border Width="64" Height="64" CornerRadius="32" Background="#441a4dcc" BorderBrush="#1a4dcc" BorderThickness="2" HorizontalAlignment="Center" Margin="0,0,0,20">
                                <TextBlock Text="JH" Foreground="#FF1a4dcc" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="JH Gaming" Foreground="White" FontSize="17" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock Text="线上直邀" Foreground="{DynamicResource TextMutedBrush}" FontSize="13" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </helpers:RevealBorder>

                    <!-- CY Gaming -->
                    <helpers:RevealBorder Grid.Column="4" Style="{StaticResource TileRevealStyle}" HoverColor="#44FF6B00" HoverRadius="200" Background="{DynamicResource ItemBgBrush}" CornerRadius="16" Padding="24,32">
                        <StackPanel>
                            <Border Width="64" Height="64" CornerRadius="32" Background="#4400875a" BorderBrush="#00875a" BorderThickness="2" HorizontalAlignment="Center" Margin="0,0,0,20">
                                <TextBlock Text="CY" Foreground="#FF00875a" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="CY Gaming" Foreground="White" FontSize="17" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock Text="线上直邀" Foreground="{DynamicResource TextMutedBrush}" FontSize="13" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </helpers:RevealBorder>
                </Grid>

                <helpers:RevealBorder Style="{StaticResource TileRevealStyle}" CornerRadius="20" Margin="0,48,0,0" Padding="40">
                    <StackPanel>
                        <TextBlock Text="关于 Yachiyo Cup" Style="{StaticResource TitleStyle}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20"/>
                        <TextBlock Text="Yachiyo Cup（YCP）是由同学们自发组织的无畏契约友谊赛。我们相信竞技的乐趣在于参与和成长，无论水平高低，每个人都能在比赛中找到属于自己的高光时刻。" 
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="15" TextWrapping="Wrap" LineHeight="26"/>
                        <TextBlock Text="所有队伍间轮打一圈积分得出胜者组和败者组，一直打到不平局。然后败者组和胜者组各决出一队晋级决赛。总决赛 BO5，其余比赛 BO3。" 
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="15" TextWrapping="Wrap" LineHeight="26" Margin="0,16,0,0"/>
                    </StackPanel>
                </helpers:RevealBorder>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
