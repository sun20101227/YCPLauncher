<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:fw="clr-namespace:SourceChord.FluentWPF;assembly=FluentWPF"
                    xmlns:helpers="clr-namespace:YCPLauncher.Helpers">
    <!-- Dark Theme Brushes -->
    <SolidColorBrush x:Key="AccentBrush"      Color="#FF6B00"/>
    
    <!-- Backgrounds -->
    <SolidColorBrush x:Key="BgDeepBrush"      Color="#060A10"/>
    <SolidColorBrush x:Key="BgDarkBrush"      Color="#0A0F1A"/>
    <SolidColorBrush x:Key="BgCardBrush"      Color="#0F1623"/>
    <SolidColorBrush x:Key="BgSidebarBrush"   Color="#A0080D18"/>
    <SolidColorBrush x:Key="BgOverlayBrush"   Color="#8A060A10"/>
    
    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrush1"     Color="#1A2436"/>
    <SolidColorBrush x:Key="BorderBrush2"     Color="#111C2E"/>
    <SolidColorBrush x:Key="BorderBrushHover" Color="#FF6B00"/>
    
    <!-- Texts -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E8F0F8"/>
    <SolidColorBrush x:Key="TextMutedBrush"   Color="#4A5568"/>
    <SolidColorBrush x:Key="TextDimBrush"     Color="#2A3A50"/>
    
    <!-- Specific Elements -->
    <SolidColorBrush x:Key="CardBgBrush"      Color="#A00A1020"/>
    <SolidColorBrush x:Key="ItemBgBrush"      Color="#080D18"/>
    <SolidColorBrush x:Key="ItemBgHoverBrush" Color="#0D1525"/>
    <SolidColorBrush x:Key="ItemBorderBrush"  Color="#1A2A3A"/>
    <SolidColorBrush x:Key="AccentBgBrush"    Color="#142033"/>
    
    <!-- Status -->
    <SolidColorBrush x:Key="SuccessBrush"     Color="#22C55E"/>
    <SolidColorBrush x:Key="WarningBrush"     Color="#F59E0B"/>
    <SolidColorBrush x:Key="ErrorBrush"       Color="#EF4444"/>

    <!-- Gradient Backgrounds -->
    <RadialGradientBrush x:Key="GlowAccentBrush">
        <GradientStop Color="#1AFF6B00" Offset="0"/>
        <GradientStop Color="#00FF6B00" Offset="1"/>
    </RadialGradientBrush>
    <RadialGradientBrush x:Key="GlowBlueBrush">
        <GradientStop Color="#140055FF" Offset="0"/>
        <GradientStop Color="#000055FF" Offset="1"/>
    </RadialGradientBrush>

    <!-- Shadow Colors -->
    <Color x:Key="ShadowColor">#000000</Color>

    <!-- Win10 Tile Reveal Style for RevealBorder -->
    <Style x:Key="TileRevealStyle" TargetType="helpers:RevealBorder">
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="HoverColor" Value="#66FF6B00"/>
        <Setter Property="HoverRadius" Value="300"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#FF6B00" BlurRadius="20" ShadowDepth="0" Opacity="0"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.02" Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction><QuarticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.02" Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction><QuarticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)" To="0.5" Duration="0:0:0.3"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.3">
                            <DoubleAnimation.EasingFunction><QuarticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.3">
                            <DoubleAnimation.EasingFunction><QuarticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)" To="0" Duration="0:0:0.4"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="PreviewMouseDown">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0.98" Duration="0:0:0.1">
                            <DoubleAnimation.EasingFunction><QuarticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="0.98" Duration="0:0:0.1">
                            <DoubleAnimation.EasingFunction><QuarticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)" To="0.2" Duration="0:0:0.1"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="PreviewMouseUp">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.02" Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction><QuarticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.02" Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction><QuarticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)" To="0.5" Duration="0:0:0.2"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
