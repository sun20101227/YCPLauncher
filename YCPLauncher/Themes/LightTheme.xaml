<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:helpers="clr-namespace:YCPLauncher.Helpers">
    <!-- Light Theme Brushes -->
    <SolidColorBrush x:Key="AccentBrush"      Color="#FF6B00"/>
    
    <!-- Backgrounds -->
    <SolidColorBrush x:Key="BgDeepBrush"      Color="#F0F4F8"/>
    <SolidColorBrush x:Key="BgDarkBrush"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BgCardBrush"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BgSidebarBrush"   Color="#F7FAFC"/>
    <SolidColorBrush x:Key="BgOverlayBrush"   Color="#8AFFFFFF"/>
    
    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrush1"     Color="#E2E8F0"/>
    <SolidColorBrush x:Key="BorderBrush2"     Color="#CBD5E1"/>
    <SolidColorBrush x:Key="BorderBrushHover" Color="#FF6B00"/>
    
    <!-- Texts -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F172A"/>
    <SolidColorBrush x:Key="TextMutedBrush"   Color="#475569"/>
    <SolidColorBrush x:Key="TextDimBrush"     Color="#94A3B8"/>
    
    <!-- Specific Elements -->
    <SolidColorBrush x:Key="CardBgBrush"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ItemBgBrush"      Color="#F8FAFC"/>
    <SolidColorBrush x:Key="ItemBgHoverBrush" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="ItemBorderBrush"  Color="#E2E8F0"/>
    <SolidColorBrush x:Key="AccentBgBrush"    Color="#FFF7ED"/>
    
    <!-- Status -->
    <SolidColorBrush x:Key="SuccessBrush"     Color="#16A34A"/>
    <SolidColorBrush x:Key="WarningBrush"     Color="#D97706"/>
    <SolidColorBrush x:Key="ErrorBrush"       Color="#DC2626"/>

    <!-- Gradient Backgrounds -->
    <RadialGradientBrush x:Key="GlowAccentBrush">
        <GradientStop Color="#1AFF6B00" Offset="0"/>
        <GradientStop Color="#00FF6B00" Offset="1"/>
    </RadialGradientBrush>
    <RadialGradientBrush x:Key="GlowBlueBrush">
        <GradientStop Color="#143B82F6" Offset="0"/>
        <GradientStop Color="#003B82F6" Offset="1"/>
    </RadialGradientBrush>

    <!-- Shadow Colors -->
    <Color x:Key="ShadowColor">#40000000</Color>

    <!-- Win10 Tile Reveal Style for RevealBorder -->
    <Style x:Key="TileRevealStyle" TargetType="helpers:RevealBorder">
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="HoverColor" Value="#22000000"/>
        <Setter Property="HoverRadius" Value="350"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#22000000"/>
        <Setter Property="Padding" Value="24"/>
        <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.02" Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.02" Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.3">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.3">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
