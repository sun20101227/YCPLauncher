<Window x:Class="YCPLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:YCPLauncher.Views"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        mc:Ignorable="d"
        Title="Yachiyo Cup"
        Height="720"
        Width="1080"
        MinHeight="580"
        MinWidth="860"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        Background="Transparent"
        Icon="app.ico"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="-1"
                      CaptionHeight="42"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="CaptionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="2,2,0,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ChromeSurface"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChromeSurface"
                                        Property="Background"
                                        Value="{DynamicResource CaptionHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ChromeSurface"
                                        Property="Background"
                                        Value="{DynamicResource CaptionPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseCaptionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource CaptionButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ChromeSurface"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter x:Name="ChromeContent"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChromeSurface" Property="Background" Value="#E5484D"/>
                                <Setter TargetName="ChromeContent" Property="TextElement.Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ChromeSurface" Property="Background" Value="#C83C42"/>
                                <Setter TargetName="ChromeContent" Property="TextElement.Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CompactNavButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource NavButton}">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="HarmonyOS Sans SC, Microsoft YaHei UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <ContextMenu x:Key="SysTrayMenu"
                     Background="{DynamicResource BgSidebarBrush}"
                     BorderBrush="{DynamicResource BorderBrush1}"
                     BorderThickness="1">
            <ContextMenu.Template>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="9">
                        <StackPanel IsItemsHost="True"
                                    KeyboardNavigation.DirectionalNavigation="Cycle"
                                    Margin="0,5"/>
                    </Border>
                </ControlTemplate>
            </ContextMenu.Template>
            <ContextMenu.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="Padding" Value="14,8"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="MenuItem">
                                <Border x:Name="MenuSurface"
                                        Background="Transparent"
                                        CornerRadius="6"
                                        Margin="5,2">
                                    <ContentPresenter ContentSource="Header" Margin="10,5"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="MenuSurface"
                                                Property="Background"
                                                Value="{DynamicResource AccentBgBrush}"/>
                                        <Setter Property="Foreground"
                                                Value="{DynamicResource AccentBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ContextMenu.Resources>
            <MenuItem Header="显示面板" Click="TrayShow_Click"/>
            <MenuItem Header="退出 Yachiyo Cup" Click="TrayExit_Click"/>
        </ContextMenu>
    </Window.Resources>

    <Border Background="Transparent">
        <Grid ClipToBounds="True">
            <!-- Login and authenticated pages deliberately share this exact background. -->
            <Grid x:Name="WallpaperRoot"
                  Background="{DynamicResource WallpaperBaseBrush}"
                  ClipToBounds="True">
                <MediaElement x:Name="AmbientVideo"
                              Source="Assets/login_bg.mp4"
                              Stretch="UniformToFill"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              LoadedBehavior="Manual"
                              UnloadedBehavior="Close"
                              IsMuted="True"
                              Volume="0"
                              SpeedRatio="1"
                              Opacity="{DynamicResource AmbientVideoOpacity}"
                              IsHitTestVisible="False"
                              Focusable="False"
                              RenderOptions.BitmapScalingMode="LowQuality"
                              Visibility="Collapsed"
                              MediaOpened="AmbientVideo_MediaOpened"
                              MediaEnded="AmbientVideo_MediaEnded"
                              MediaFailed="AmbientVideo_MediaFailed"/>
                <!-- One theme-aware tint/vignette layer replaces the opaque light-theme
                     overlay and avoids compositing two full-window rectangles. -->
                <Rectangle x:Name="AmbientThemeMask"
                           Fill="{DynamicResource AmbientMaskBrush}"
                           IsHitTestVisible="False"/>
            </Grid>

            <Grid x:Name="InnerGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarCol" Width="164"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="SidebarBorder"
                        Grid.Column="0"
                        Margin="10,10,0,10"
                        Background="{DynamicResource BgSidebarBrush}"
                        BorderBrush="{DynamicResource BorderBrush1}"
                        BorderThickness="1"
                        CornerRadius="16">
                    <Grid Margin="9">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="68"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="7,12,7,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="38"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="34"
                                    Height="34"
                                    CornerRadius="10"
                                    Background="{DynamicResource AccentBgBrush}">
                                <Image Source="/Assets/logo.png"
                                       Width="26"
                                       Height="26"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <StackPanel Grid.Column="1"
                                        Margin="9,0,0,0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="YACHIYO"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="CUP · CS2"
                                           Margin="0,2,0,0"
                                           FontSize="9"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel x:Name="NavPanel" Grid.Row="1" Margin="0,18,0,0">
                            <TextBlock Text="NAVIGATION"
                                       Margin="10,0,0,9"
                                       FontSize="8"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextDimBrush}"
                                       Opacity="0.7"/>

                            <Button x:Name="NavIntro"
                                    Style="{StaticResource CompactNavButtonStyle}"
                                    Click="NavIntro_Click"
                                    Margin="0,0,0,5"
                                    Tag="Intro">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3"/>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="IntroIndicator"
                                            Width="3"
                                            Height="18"
                                            Background="{DynamicResource AccentBrush}"
                                            CornerRadius="2"
                                            Visibility="Hidden"/>
                                    <TextBlock Grid.Column="1"
                                               Text="&#xE946;"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="14"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2"
                                               Text="赛事介绍"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Button>

                            <Button x:Name="NavDashboard"
                                    Style="{StaticResource CompactNavButtonStyle}"
                                    Click="NavDashboard_Click"
                                    Margin="0,0,0,5"
                                    Tag="Dashboard">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3"/>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="DashboardIndicator"
                                            Width="3"
                                            Height="18"
                                            Background="{DynamicResource AccentBrush}"
                                            CornerRadius="2"
                                            Visibility="Hidden"/>
                                    <TextBlock Grid.Column="1"
                                               Text="&#xE77B;"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="14"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2"
                                               Text="选手信息"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Button>

                            <Button x:Name="NavMatchmaking"
                                    Style="{StaticResource CompactNavButtonStyle}"
                                    Click="NavMatchmaking_Click"
                                    Margin="0,0,0,5"
                                    Tag="Matchmaking">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3"/>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="MatchmakingIndicator"
                                            Width="3"
                                            Height="18"
                                            Background="{DynamicResource AccentBrush}"
                                            CornerRadius="2"
                                            Visibility="Hidden"/>
                                    <TextBlock Grid.Column="1"
                                               Text="&#xE7FC;"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="14"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2"
                                               Text="匹配竞技"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Button>

                            <Button x:Name="NavLiveStream"
                                    Style="{StaticResource CompactNavButtonStyle}"
                                    Click="NavLiveStream_Click"
                                    Margin="0,0,0,5"
                                    Tag="LiveStream">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3"/>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="LiveStreamIndicator"
                                            Width="3"
                                            Height="18"
                                            Background="{DynamicResource AccentBrush}"
                                            CornerRadius="2"
                                            Visibility="Hidden"/>
                                    <TextBlock Grid.Column="1"
                                               Text="&#xE714;"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="14"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2"
                                               Text="观看直播"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Button>
                        </StackPanel>

                        <StackPanel Grid.Row="2">
                            <Rectangle Height="1"
                                       Margin="8,0,8,9"
                                       Fill="{DynamicResource BorderBrush1}"/>
                            <Button x:Name="NavSettings"
                                    Style="{StaticResource CompactNavButtonStyle}"
                                    Click="NavSettings_Click"
                                    Margin="0,0,0,8"
                                    Tag="Settings">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3"/>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="SettingsIndicator"
                                            Width="3"
                                            Height="18"
                                            Background="{DynamicResource AccentBrush}"
                                            CornerRadius="2"
                                            Visibility="Hidden"/>
                                    <TextBlock Grid.Column="1"
                                               Text="&#xE713;"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="14"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2"
                                               Text="系统设置"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Button>
                            <Grid Margin="10,0,10,5">
                                <TextBlock x:Name="TxtVersion"
                                           FontSize="9"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Opacity="0.72"/>
                                <Ellipse Width="5"
                                         Height="5"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Center"
                                         Fill="{DynamicResource AccentBrush}"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="1" Background="Transparent">
                        <ContentControl x:Name="MainContent" Background="Transparent"/>
                        <views:ToastNotification x:Name="Toast"
                                                 VerticalAlignment="Bottom"
                                                 HorizontalAlignment="Center"
                                                 Margin="0,0,0,28"
                                                 Panel.ZIndex="99"/>
                    </Grid>
                </Grid>
            </Grid>

            <ContentControl x:Name="LoginOverlay"
                            Margin="0"
                            Background="Transparent"
                            Visibility="Collapsed"/>

            <!-- A single understated title treatment is shared by every state. -->
            <Grid Height="42"
                  VerticalAlignment="Top"
                  Panel.ZIndex="200"
                  IsHitTestVisible="True">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,0,8,0">
                    <Button Style="{StaticResource CaptionButtonStyle}"
                            Click="MinBtn_Click"
                            ToolTip="最小化">
                        <TextBlock Text="&#xE921;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Arial"
                                   FontSize="10"/>
                    </Button>
                    <Button x:Name="MaxBtn"
                            Style="{StaticResource CaptionButtonStyle}"
                            Click="MaxBtn_Click"
                            ToolTip="最大化">
                        <TextBlock x:Name="MaxIcon"
                                   Text="&#xE922;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Arial"
                                   FontSize="10"/>
                    </Button>
                    <Button Style="{StaticResource CloseCaptionButtonStyle}"
                            Click="CloseBtn_Click"
                            ToolTip="关闭">
                        <TextBlock Text="&#xE8BB;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Arial"
                                   FontSize="10"/>
                    </Button>
                </StackPanel>
            </Grid>

            <tb:TaskbarIcon x:Name="MyNotifyIcon"
                            IconSource="app.ico"
                            ToolTipText="Yachiyo Cup"
                            ContextMenu="{StaticResource SysTrayMenu}"
                            TrayMouseDoubleClick="TrayIcon_DoubleClick"/>
        </Grid>
    </Border>
</Window>
