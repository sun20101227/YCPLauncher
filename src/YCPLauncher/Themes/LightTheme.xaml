<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
                    xmlns:helpers="clr-namespace:YCPLauncher.Helpers">
    <!-- Clear frost-white console surfaces that preserve subtle video ambience. -->
    <SolidColorBrush x:Key="AccentBrush" Color="#147D9A"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#0F708B"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#0B5F77"/>
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PrimaryHoverOverlayBrush" Color="#16FFFFFF"/>
    <SolidColorBrush x:Key="PrimaryPressedOverlayBrush" Color="#16061720"/>
    <LinearGradientBrush x:Key="WallpaperBaseBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#EAF1F5" Offset="0"/>
        <GradientStop Color="#F4F7F9" Offset="0.52"/>
        <GradientStop Color="#FFFFFF" Offset="1"/>
    </LinearGradientBrush>
    <sys:Double x:Key="AmbientVideoOpacity">0.12</sys:Double>
    <LinearGradientBrush x:Key="AmbientMaskBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#E8EAF1F5" Offset="0"/>
        <GradientStop Color="#DEF4F7F9" Offset="0.52"/>
        <GradientStop Color="#ECFFFFFF" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="BgDeepBrush" Color="#EAF0F5F8"/>
    <SolidColorBrush x:Key="BgDarkBrush" Color="#F5FFFFFF"/>
    <SolidColorBrush x:Key="BgCardBrush" Color="#EEFFFFFF"/>
    <SolidColorBrush x:Key="BgSidebarBrush" Color="#F2F8FAFC"/>
    <SolidColorBrush x:Key="BgOverlayBrush" Color="#CBEAF1F5"/>

    <SolidColorBrush x:Key="CaptionHoverBrush" Color="#14147D9A"/>
    <SolidColorBrush x:Key="CaptionPressedBrush" Color="#24147D9A"/>

    <SolidColorBrush x:Key="BorderBrush1" Color="#B9C9D4DC"/>
    <SolidColorBrush x:Key="BorderBrush2" Color="#D0B5C6D1"/>
    <SolidColorBrush x:Key="BorderBrushHover" Color="#D77FA7B7"/>
    <SolidColorBrush x:Key="CardHoverBorderBrush" Color="#A8147D9A"/>
    <SolidColorBrush x:Key="FocusRingBrush" Color="#A8147D9A"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#14222D"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#4D5E6C"/>
    <SolidColorBrush x:Key="TextDimBrush" Color="#738391"/>

    <SolidColorBrush x:Key="CardBgBrush" Color="#EBFFFFFF"/>
    <SolidColorBrush x:Key="CardHoverBrush" Color="#F8FFFFFF"/>
    <SolidColorBrush x:Key="ItemBgBrush" Color="#DCF4F8FA"/>
    <SolidColorBrush x:Key="ItemBgHoverBrush" Color="#EEF0F6F8"/>
    <SolidColorBrush x:Key="ItemBorderBrush" Color="#AFC4D1D9"/>
    <SolidColorBrush x:Key="AccentBgBrush" Color="#21147D9A"/>

    <SolidColorBrush x:Key="ControlHoverBrush" Color="#DCE8F0F4"/>
    <SolidColorBrush x:Key="ControlPressedBrush" Color="#E9DCE8ED"/>
    <SolidColorBrush x:Key="NavigationHoverBrush" Color="#CDE8F0F4"/>
    <SolidColorBrush x:Key="NavigationPressedBrush" Color="#E5DCE8ED"/>
    <SolidColorBrush x:Key="NavigationActiveBrush" Color="#25147D9A"/>

    <SolidColorBrush x:Key="MediaSurfaceBrush" Color="#E6E2EAF0"/>
    <SolidColorBrush x:Key="MediaPlaceholderBrush" Color="#EAF2F6F8"/>
    <SolidColorBrush x:Key="MediaControlsBrush" Color="#F4FFFFFF"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="#277A55"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#946619"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#B23F4A"/>

    <Color x:Key="CardRevealColor">#16147D9A</Color>

    <!-- Compatibility glows remain restrained and do not create broad bloom. -->
    <RadialGradientBrush x:Key="GlowAccentBrush">
        <GradientStop Color="#09147D9A" Offset="0"/>
        <GradientStop Color="#00147D9A" Offset="1"/>
    </RadialGradientBrush>
    <RadialGradientBrush x:Key="GlowBlueBrush">
        <GradientStop Color="#07687EF4" Offset="0"/>
        <GradientStop Color="#00687EF4" Offset="1"/>
    </RadialGradientBrush>

    <Color x:Key="ShadowColor">#180B1822</Color>
    <Color x:Key="PopupShadowColor">#30081420</Color>

    <Style x:Key="TileRevealStyle" TargetType="helpers:RevealBorder">
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="HoverColor" Value="{DynamicResource CardRevealColor}"/>
        <Setter Property="HoverRadius" Value="160"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ItemBorderBrush}"/>
        <Setter Property="Padding" Value="24"/>
        <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource CardHoverBorderBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
