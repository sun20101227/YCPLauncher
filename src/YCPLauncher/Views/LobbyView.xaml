<UserControl x:Class="YCPLauncher.Views.LobbyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1080"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="SlotJoinButton"
               TargetType="Button"
               BasedOn="{StaticResource GhostButton}">
            <Setter Property="Width" Value="62"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Background" Value="{DynamicResource AccentBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush2}"/>
        </Style>

        <!-- Compact player row -->
        <DataTemplate x:Key="PlayerSlotTemplate">
            <Grid Margin="0,0,0,6" MinHeight="44">
                <!-- Slot background -->
                <Border CornerRadius="8">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource ItemBgBrush}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource ItemBorderBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource MediaPlaceholderBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush1}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsMe}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentBgBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid Margin="11,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Name & Empty State -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Occupied Icon -->
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Arial" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Visibility="{Binding IsOccupied, Converter={StaticResource BoolToVis}}"/>
                            <!-- Empty Icon -->
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Arial" FontSize="14" Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"/>

                            <!-- Name text -->
                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Visibility="{Binding IsOccupied, Converter={StaticResource BoolToVis}}"
                                       VerticalAlignment="Center"/>

                            <!-- YOU badge -->
                            <Border Background="{DynamicResource AccentBrush}" CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center"
                                    Visibility="{Binding IsMe, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="YOU" FontSize="10" FontWeight="Black" Foreground="{DynamicResource AccentForegroundBrush}"/>
                            </Border>

                            <!-- Empty text -->
                            <TextBlock Text="等待加入..." FontSize="13" Foreground="{DynamicResource TextDimBrush}"
                                       Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <!-- Right (Join / Ready) -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border CornerRadius="4" Background="{DynamicResource ItemBgHoverBrush}" BorderBrush="{DynamicResource SuccessBrush}" BorderThickness="1" Padding="8,3" Margin="0,0,10,0"
                                    Visibility="{Binding IsReady, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="已准备" FontSize="11" Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold"/>
                            </Border>
                            <Button Content="加入"
                                    Style="{StaticResource SlotJoinButton}"
                                    Command="{Binding DataContext.JoinSlotCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- Coach row (slightly different tint) -->
        <DataTemplate x:Key="CoachSlotTemplate">
            <Grid Margin="0,4,0,0" MinHeight="44">
                <!-- Slot background -->
                <Border CornerRadius="8">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource ItemBgBrush}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource MediaPlaceholderBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush1}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsMe}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentBgBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid Margin="11,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{DynamicResource AccentBgBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,8,0" VerticalAlignment="Center">
                            <TextBlock Text="教练" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}" VerticalAlignment="Center"/>
                        </Border>

                        <!-- Name & Empty State -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Occupied Icon -->
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Arial" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Visibility="{Binding IsOccupied, Converter={StaticResource BoolToVis}}"/>
                            <!-- Empty Icon -->
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Arial" FontSize="14" Foreground="{DynamicResource WarningBrush}" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"/>

                            <!-- Name text -->
                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Visibility="{Binding IsOccupied, Converter={StaticResource BoolToVis}}"
                                       VerticalAlignment="Center"/>

                            <!-- YOU badge -->
                            <Border Background="{DynamicResource AccentBrush}" CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center"
                                    Visibility="{Binding IsMe, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="YOU" FontSize="10" FontWeight="Black" Foreground="{DynamicResource AccentForegroundBrush}"/>
                            </Border>

                            <!-- Empty text -->
                            <TextBlock Text="等待加入..." FontSize="13" Foreground="{DynamicResource TextDimBrush}"
                                       Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <!-- Right (Join / Ready) -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border CornerRadius="4" Background="{DynamicResource ItemBgHoverBrush}" BorderBrush="{DynamicResource SuccessBrush}" BorderThickness="1" Padding="8,3" Margin="0,0,10,0"
                                    Visibility="{Binding IsReady, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="已准备" FontSize="11" Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold"/>
                            </Border>
                            <Button Content="教练席"
                                    Style="{StaticResource SlotJoinButton}"
                                    Command="{Binding DataContext.JoinSlotCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- Spectator row (right panel) -->
        <DataTemplate x:Key="SpectatorRowTemplate">
            <Grid Margin="0,0,0,6" MinHeight="44">
                <!-- Slot background -->
                <Border CornerRadius="8">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource ItemBgBrush}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource ItemBorderBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource MediaPlaceholderBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush1}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsMe}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentBgBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid Margin="11,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Name & Empty State -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Occupied Icon -->
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Arial" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Visibility="{Binding IsOccupied, Converter={StaticResource BoolToVis}}"/>
                            <!-- Empty Icon -->
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Arial" FontSize="14" Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"/>

                            <!-- Name text -->
                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Visibility="{Binding IsOccupied, Converter={StaticResource BoolToVis}}"
                                       VerticalAlignment="Center"/>

                            <!-- YOU badge -->
                            <Border Background="{DynamicResource AccentBrush}" CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center"
                                    Visibility="{Binding IsMe, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="YOU" FontSize="10" FontWeight="Black" Foreground="{DynamicResource AccentForegroundBrush}"/>
                            </Border>

                            <!-- Empty text -->
                            <TextBlock Text="等待加入..." FontSize="13" Foreground="{DynamicResource TextDimBrush}"
                                       Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <!-- Right (Join) -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="加入"
                                    Style="{StaticResource SlotJoinButton}"
                                    Command="{Binding DataContext.JoinSlotCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>

        <Storyboard x:Key="ShakeAnimation">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)">
                <EasingDoubleKeyFrame KeyTime="0:0:0.00" Value="-8"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.05" Value="8"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.10" Value="-8"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.15" Value="8"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.20" Value="-4"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="4"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.30" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>

    <!-- Outer container to anchor everything -->
    <Grid x:Name="LobbyRoot" Opacity="1">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="LobbyTranslate"/>
        </Grid.RenderTransform>

        <!-- ════════ ENTRY MODE (Create / Join Screen) ════════ -->
        <Grid Visibility="{Binding IsInEntryMode, Converter={StaticResource BoolToVis}}">
            <Border Width="900" Background="{DynamicResource CardBgBrush}" CornerRadius="16"
                    BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Padding="34,30">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" HorizontalAlignment="Left">
                        <TextBlock Text="创建或加入比赛房间" FontSize="24" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="邀请队友、选择阵营，然后一起进入比赛服务器"
                                   Margin="0,7,0,0" FontSize="13"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="22"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{DynamicResource ItemBgBrush}"
                                CornerRadius="12" BorderBrush="{DynamicResource BorderBrush1}"
                                BorderThickness="1" Padding="24">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock Text="新建房间" FontSize="17" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="生成六位房间码，邀请朋友进入同一个比赛大厅。"
                                               Margin="0,8,0,0" FontSize="12" TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>
                                <Button Grid.Row="2" Width="154" Height="38" Margin="0,22,0,0"
                                        HorizontalAlignment="Left"
                                        Command="{Binding CreateNewRoomCommand}"
                                        IsEnabled="{Binding CanJoinOrCreate}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource OrangeButton}">
                                            <Setter Property="Content" Value="创建房间"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCreatingRoom}" Value="True">
                                                    <Setter Property="Content" Value="正在创建..."/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Background="{DynamicResource ItemBgBrush}"
                                CornerRadius="12" BorderBrush="{DynamicResource BorderBrush1}"
                                BorderThickness="1" Padding="24">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock Text="加入已有房间" FontSize="17" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="输入朋友发来的六位房间码。"
                                               Margin="0,8,0,0" FontSize="12"
                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,22,0,0">
                                    <Border x:Name="RoomCodeBorder" Width="150" Height="38"
                                            Background="{DynamicResource BgDarkBrush}"
                                            BorderThickness="1" CornerRadius="8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush2}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRoomCodeInvalid}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                                                        <Setter Property="Background" Value="{DynamicResource AccentBgBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.RenderTransform>
                                            <TranslateTransform X="0" Y="0"/>
                                        </Border.RenderTransform>
                                        <TextBox Text="{Binding RoomCodeInput, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource CenteredTextBoxStyle}"
                                                 FontSize="18" FontWeight="Bold"
                                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                                 Background="Transparent" BorderThickness="0"
                                                 VerticalAlignment="Stretch" VerticalContentAlignment="Center"
                                                 HorizontalContentAlignment="Center" TextAlignment="Center"
                                                 Padding="0" CharacterCasing="Upper" MaxLength="6"
                                                 IsEnabled="{Binding CanJoinOrCreate}"/>
                                    </Border>
                                    <Button Width="112" Height="38" Margin="10,0,0,0"
                                            Command="{Binding JoinByCodeCommand}"
                                            IsEnabled="{Binding CanJoinOrCreate}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                                <Setter Property="Content" Value="加入房间"/>
                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush2}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsJoiningRoom}" Value="True">
                                                        <Setter Property="Content" Value="正在加入..."/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="3" Margin="0,18,0,0">
                        <TextBlock Text="{Binding LobbyStatus}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ErrorBrush}"
                                   Visibility="{Binding IsRoomCodeInvalid, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Text="{Binding LobbySubStatus}" Margin="0,3,0,0" FontSize="11"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   Visibility="{Binding IsRoomCodeInvalid, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ════════ ROOM MODE (Actual Lobby) ════════ -->
        <DockPanel Margin="28,20,28,20" Visibility="{Binding IsInRoomMode, Converter={StaticResource BoolToVis}}">

            <!-- Header -->
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="4" Height="20" Fill="{DynamicResource AccentBrush}"
                                       RadiusX="2" RadiusY="2" Margin="0,0,10,0"/>
                            <TextBlock Text="房间大厅" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <TextBlock Text="选择阵营与席位；所有选手准备后，由主席启动比赛。"
                                   Foreground="{DynamicResource TextDimBrush}" Margin="14,5,0,0" FontSize="12"/>
                    </StackPanel>

                    <!-- Display Room Code at top right -->
                    <Border Grid.Column="1" Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1" CornerRadius="10" Padding="14,7" VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="房间码 " FontSize="12" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding DisplayRoomCode}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <Button Content="{Binding CopyStatusText}" Width="50" Height="22" Margin="10,0,0,0" Padding="0" FontSize="11"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding CopyRoomCodeCommand}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <!-- Action Bar (Rounded Box at bottom) -->
            <Border DockPanel.Dock="Bottom" Margin="0,12,0,0" CornerRadius="12"
                    Background="{DynamicResource CardBgBrush}"
                    BorderThickness="1" BorderBrush="{DynamicResource BorderBrush2}"
                    Padding="18,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding LobbyStatus}" FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                            <TextBlock Text="{Binding LobbySubStatus}" FontSize="12"
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                            <TextBlock Text="{Binding PlayerCountText}" FontSize="12"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="15,0,0,0"
                                       Visibility="{Binding IsInRoomMode, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" Content="{Binding LeaveButtonText}" Width="110" Height="36" Margin="0,0,10,0"
                            Style="{StaticResource GhostButton}" Foreground="{DynamicResource ErrorBrush}"
                            Command="{Binding LeaveRoomCommand}"/>
                    <Button Grid.Column="2" Content="离开席位" Width="90" Height="36" Margin="0,0,10,0"
                            Style="{StaticResource GhostButton}" Foreground="{DynamicResource TextMutedBrush}"
                            Command="{Binding LeaveSlotCommand}"
                            Visibility="{Binding HasJoined, Converter={StaticResource BoolToVis}}"/>
                    <Button Grid.Column="3" Content="准备" Width="92" Height="36" Margin="0,0,10,0"
                            Style="{StaticResource GhostButton}"
                            Foreground="{DynamicResource SuccessBrush}"
                            BorderBrush="{DynamicResource SuccessBrush}"
                            Command="{Binding ReadyCommand}"
                            Visibility="{Binding CanReady, Converter={StaticResource BoolToVis}}"/>
                    <Button Grid.Column="4" Content="开始比赛" Width="120" Height="36"
                            Style="{StaticResource OrangeButton}"
                            Command="{Binding StartGameCommand}"
                            IsEnabled="{Binding CanStartGame}"/>
                </Grid>
            </Border>

            <!-- Main 3-column content -->
            <Border Background="{DynamicResource CardBgBrush}" CornerRadius="14" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1" Padding="18">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>   <!-- CT -->
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>   <!-- T -->
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="240"/> <!-- Spectators fixed width -->
                        </Grid.ColumnDefinitions>

                        <!-- ── CT Column ── -->
                        <StackPanel Grid.Column="0">
                            <!-- Team label -->
                            <StackPanel Orientation="Horizontal" Margin="6,0,0,8">
                                <TextBlock Text="反恐精英" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                                <TextBlock Text=" CT" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                                <TextBlock Text="{Binding CtCountText}" FontSize="11" Foreground="{DynamicResource TextDimBrush}"
                                           VerticalAlignment="Bottom" Margin="6,0,0,2"/>
                            </StackPanel>
                            <!-- 5 player slots -->
                            <ItemsControl ItemsSource="{Binding CtSlots}" ItemTemplate="{StaticResource PlayerSlotTemplate}"/>
                            <!-- Thin separator -->
                            <Rectangle Height="1" Fill="{DynamicResource BorderBrush1}" Margin="6,6,0,0"/>
                            <!-- Coach -->
                            <ContentPresenter Content="{Binding CoachCTSlot}" ContentTemplate="{StaticResource CoachSlotTemplate}"/>
                        </StackPanel>

                        <!-- ── T Column ── -->
                        <StackPanel Grid.Column="2">
                            <StackPanel Orientation="Horizontal" Margin="6,0,0,8">
                                <TextBlock Text="恐怖分子" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}"/>
                                <TextBlock Text=" T" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}"/>
                                <TextBlock Text="{Binding TCountText}" FontSize="11" Foreground="{DynamicResource TextDimBrush}"
                                           VerticalAlignment="Bottom" Margin="6,0,0,2"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding TSlots}" ItemTemplate="{StaticResource PlayerSlotTemplate}"/>
                            <Rectangle Height="1" Fill="{DynamicResource BorderBrush1}" Margin="6,6,0,0"/>
                            <ContentPresenter Content="{Binding CoachTSlot}" ContentTemplate="{StaticResource CoachSlotTemplate}"/>
                        </StackPanel>

                        <!-- ── Spectator / Host Column ── -->
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="主席 / 观战" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="6,0,0,8"/>
                            <!-- Host (主席) -->
                            <TextBlock Text="主席" FontSize="10" Foreground="{DynamicResource TextDimBrush}" Margin="6,0,0,3"/>
                            <ContentPresenter Content="{Binding HostSlot}" ContentTemplate="{StaticResource SpectatorRowTemplate}"/>
                            <!-- Spectator slots (visual, pending backend support) -->
                            <Rectangle Height="1" Fill="{DynamicResource BorderBrush1}" Margin="6,8,0,8"/>
                            <TextBlock Text="观战  （开发中）" FontSize="10" Foreground="{DynamicResource TextDimBrush}" Margin="6,0,0,4"/>
                            <Border Margin="6,0,0,0" Padding="14,18" CornerRadius="8"
                                    Background="{DynamicResource MediaPlaceholderBrush}"
                                    BorderBrush="{DynamicResource BorderBrush1}" BorderThickness="1"
                                    IsHitTestVisible="False">
                                <StackPanel>
                                    <TextBlock Text="观战席尚未开放" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBlock Text="后端支持完成后会在这里显示观战成员"
                                               Margin="0,5,0,0" FontSize="10" TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextDimBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>

        </DockPanel>

    </Grid>
</UserControl>
