<UserControl x:Class="YCPLauncher.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:YCPLauncher.Helpers"
             mc:Ignorable="d"
             Background="Transparent"
             d:DesignHeight="800"
             d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="SettingsToggleSwitch" TargetType="CheckBox">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="40" Height="22" Background="Transparent">
                            <Border x:Name="Track"
                                    Background="{DynamicResource BorderBrush2}"
                                    BorderBrush="{DynamicResource BorderBrush1}"
                                    BorderThickness="1"
                                    CornerRadius="11"/>
                            <Border x:Name="Thumb"
                                    Width="16"
                                    Height="16"
                                    Margin="3,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="White"
                                    CornerRadius="8">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="5"
                                                      ShadowDepth="1"
                                                      Opacity="0.22"/>
                                </Border.Effect>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="21,0,0,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.86"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Track" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.45"/>
                                <Setter TargetName="Thumb" Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsGroup" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush1}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="SettingsRow" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="14,11"/>
            <Setter Property="CornerRadius" Value="9"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ItemBgBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SettingTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="SettingDescription" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="CompactActionButton"
               TargetType="Button"
               BasedOn="{StaticResource GhostButton}">
            <Setter Property="Height" Value="29"/>
            <Setter Property="MinWidth" Value="68"/>
            <Setter Property="Padding" Value="11,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>

        <Style x:Key="DangerActionButton" TargetType="Button">
            <Setter Property="Height" Value="29"/>
            <Setter Property="MinWidth" Value="68"/>
            <Setter Property="Padding" Value="11,0"/>
            <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="DangerBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DangerBorder" Property="Background" Value="#18EF4444"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="DangerBorder" Property="Background" Value="#2AEF4444"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="DangerBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldBorder" TargetType="Border">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="Background" Value="{DynamicResource BgSidebarBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="7"/>
        </Style>

        <Style x:Key="SettingsTextBox" TargetType="TextBox"
               BasedOn="{StaticResource CenteredTextBoxStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="9,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  helpers:SmoothScrollViewerBehavior.IsEnabled="True">
        <Grid x:Name="PageRoot"
              Margin="28,18,24,28"
              MaxWidth="980"
              HorizontalAlignment="Stretch"
              Opacity="1">
            <Grid.RenderTransform>
                <TranslateTransform Y="0"/>
            </Grid.RenderTransform>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Command="{Binding GoBackCommand}"
                        Visibility="{Binding IsLoggedOut, Converter={StaticResource BoolToVisibility}}"
                        Style="{StaticResource CompactActionButton}"
                        Margin="0,0,12,0"
                        Padding="9,0"
                        MinWidth="0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72B;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="11"
                                   Margin="0,0,6,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="返回登录" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="设置"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="24"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="调整启动器、游戏连接与本地维护选项"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="11.5"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <Border Grid.Column="2"
                        Padding="10,5"
                        VerticalAlignment="Top"
                        Background="{DynamicResource AccentBgBrush}"
                        BorderBrush="{DynamicResource BorderBrush1}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6"
                                 Height="6"
                                 Margin="0,0,7,0"
                                 VerticalAlignment="Center"
                                 Fill="{DynamicResource AccentBrush}"/>
                        <TextBlock Text="{Binding CurrentVersion, Mode=OneWay}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontFamily="Consolas"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Account security, kept as a single compact strip -->
            <Border Grid.Row="1"
                    Style="{StaticResource SettingsGroup}"
                    Margin="0,0,0,16">
                <Grid Margin="15,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="34"
                            Height="34"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            Background="{DynamicResource AccentBgBrush}"
                            CornerRadius="9">
                        <TextBlock Text="&#xE72E;"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="15"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="账号与安全" Style="{StaticResource SettingTitle}"/>
                        <TextBlock Text="定期更新密码，保护赛事账号与个人数据"
                                   Style="{StaticResource SettingDescription}"/>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Command="{Binding ChangePasswordCommand}"
                            Content="修改密码"
                            Style="{StaticResource CompactActionButton}"
                            Margin="16,0,0,0"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Compact two-column settings layout -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left column -->
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="3,0,0,8">
                        <TextBlock Text="&#xE790;"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="13"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="外观与行为" Style="{StaticResource SectionTitle}"/>
                    </StackPanel>

                    <Border Style="{StaticResource SettingsGroup}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                        <TextBlock Text="沉浸深色外观" Style="{StaticResource SettingTitle}"/>
                                        <TextBlock Text="启用深色主题、动态背景与环境光影"
                                                   Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                    <CheckBox Grid.Column="1"
                                              IsChecked="{Binding IsDarkMode}"
                                              Style="{StaticResource SettingsToggleSwitch}"/>
                                </Grid>
                            </Border>
                            <Border Height="1" Margin="14,0" Background="{DynamicResource BorderBrush1}"/>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                        <TextBlock Text="减轻动画效果" Style="{StaticResource SettingTitle}"/>
                                        <TextBlock Text="精简非必要的缩放和环境特效"
                                                   Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                    <CheckBox Grid.Column="1"
                                              IsChecked="{Binding ReduceAnimations}"
                                              Style="{StaticResource SettingsToggleSwitch}"/>
                                </Grid>
                            </Border>
                            <Border Height="1" Margin="14,0" Background="{DynamicResource BorderBrush1}"/>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                        <TextBlock Text="关闭时最小化到托盘" Style="{StaticResource SettingTitle}"/>
                                        <TextBlock Text="点击关闭按钮时保留后台运行"
                                                   Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                    <CheckBox Grid.Column="1"
                                              IsChecked="{Binding MinimizeToTray}"
                                              Style="{StaticResource SettingsToggleSwitch}"/>
                                </Grid>
                            </Border>
                            <Border Height="1" Margin="14,0" Background="{DynamicResource BorderBrush1}"/>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                        <TextBlock Text="开机自动启动" Style="{StaticResource SettingTitle}"/>
                                        <TextBlock Text="登录 Windows 后自动运行启动器"
                                                   Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                    <CheckBox Grid.Column="1"
                                              IsChecked="{Binding StartOnBoot}"
                                              Style="{StaticResource SettingsToggleSwitch}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" Margin="3,18,0,8">
                        <TextBlock Text="&#xE7FC;"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="13"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="游戏与连接" Style="{StaticResource SectionTitle}"/>
                    </StackPanel>

                    <Border Style="{StaticResource SettingsGroup}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                        <TextBlock Text="跳过启动动画" Style="{StaticResource SettingTitle}"/>
                                        <TextBlock Text="-novid · 缩短游戏启动等待"
                                                   Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                    <CheckBox Grid.Column="1"
                                              IsChecked="{Binding LaunchNoVid}"
                                              Style="{StaticResource SettingsToggleSwitch}"/>
                                </Grid>
                            </Border>
                            <Border Height="1" Margin="14,0" Background="{DynamicResource BorderBrush1}"/>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                        <TextBlock Text="高刷新率模式" Style="{StaticResource SettingTitle}"/>
                                        <TextBlock Text="-freq 240 · 强制以 240Hz 运行"
                                                   Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                    <CheckBox Grid.Column="1"
                                              IsChecked="{Binding LaunchHighFreq}"
                                              Style="{StaticResource SettingsToggleSwitch}"/>
                                </Grid>
                            </Border>
                            <Border Height="1" Margin="14,0" Background="{DynamicResource BorderBrush1}"/>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                        <TextBlock Text="启动控制台" Style="{StaticResource SettingTitle}"/>
                                        <TextBlock Text="-console · 进入游戏后自动打开控制台"
                                                   Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                    <CheckBox Grid.Column="1"
                                              IsChecked="{Binding LaunchConsole}"
                                              Style="{StaticResource SettingsToggleSwitch}"/>
                                </Grid>
                            </Border>
                            <Border Height="1" Margin="14,0" Background="{DynamicResource BorderBrush1}"/>
                            <Border Style="{StaticResource SettingsRow}">
                                <StackPanel>
                                    <TextBlock Text="Steam 启动方式" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Text="连接无响应时可切换其他兼容协议"
                                               Style="{StaticResource SettingDescription}"/>
                                    <ComboBox SelectedIndex="{Binding LaunchMethod}"
                                              Height="34"
                                              Margin="0,8,0,0"
                                              Padding="8,3"
                                              Background="{DynamicResource BgSidebarBrush}"
                                              Foreground="{DynamicResource TextPrimaryBrush}"
                                              BorderBrush="{DynamicResource BorderBrush2}"
                                              FontSize="12"
                                              VerticalContentAlignment="Center">
                                        <ComboBoxItem Content="Steam 游戏协议"/>
                                        <ComboBoxItem Content="Steam 客户端参数"/>
                                        <ComboBoxItem Content="Steam 直连协议"/>
                                    </ComboBox>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right column -->
                <StackPanel Grid.Column="2">
                    <StackPanel Orientation="Horizontal" Margin="3,0,0,8">
                        <TextBlock Text="&#xE968;"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="13"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="网络服务" Style="{StaticResource SectionTitle}"/>
                    </StackPanel>

                    <Border Style="{StaticResource SettingsGroup}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRow}">
                                <StackPanel>
                                    <TextBlock Text="登录与 API 服务器" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Text="基础服务、登录与玩家数据接口"
                                               Style="{StaticResource SettingDescription}"/>
                                    <Border Style="{StaticResource FieldBorder}">
                                        <TextBox Text="{Binding ApiBaseUrl, UpdateSourceTrigger=LostFocus}"
                                                 Style="{StaticResource SettingsTextBox}"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <Border Height="1" Margin="14,0" Background="{DynamicResource BorderBrush1}"/>
                            <Border Style="{StaticResource SettingsRow}">
                                <StackPanel>
                                    <TextBlock Text="RTMP 直播源" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Text="赛事直播使用的拉流地址"
                                               Style="{StaticResource SettingDescription}"/>
                                    <Border Style="{StaticResource FieldBorder}">
                                        <TextBox Text="{Binding LiveStreamUrl, UpdateSourceTrigger=LostFocus}"
                                                 Style="{StaticResource SettingsTextBox}"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" Margin="3,18,0,8">
                        <TextBlock Text="&#xE74D;"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="13"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="系统维护" Style="{StaticResource SectionTitle}"/>
                    </StackPanel>

                    <Border Style="{StaticResource SettingsGroup}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <TextBlock Text="检查更新" Style="{StaticResource SettingTitle}"/>
                                        <TextBlock Style="{StaticResource SettingDescription}">
                                            <Run Text="当前版本 "/>
                                            <Run Text="{Binding CurrentVersion, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Command="{Binding CheckUpdateCommand}"
                                            Content="检查"
                                            Style="{StaticResource CompactActionButton}"
                                            VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Height="1" Margin="14,0" Background="{DynamicResource BorderBrush1}"/>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <TextBlock Text="更新日志" Style="{StaticResource SettingTitle}"/>
                                        <TextBlock Text="查看历史版本的更新记录"
                                                   Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Command="{Binding ViewChangelogCommand}"
                                            Content="查看"
                                            Style="{StaticResource CompactActionButton}"
                                            VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Height="1" Margin="14,0" Background="{DynamicResource BorderBrush1}"/>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <TextBlock Text="清理本地缓存" Style="{StaticResource SettingTitle}"/>
                                        <TextBlock Text="移除图片缓存与临时文件"
                                                   Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Command="{Binding ClearCacheCommand}"
                                            Content="清理"
                                            Style="{StaticResource CompactActionButton}"
                                            VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Height="1" Margin="14,0" Background="{DynamicResource BorderBrush1}"/>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <TextBlock Text="卸载 YCP 启动器"
                                                   Foreground="{DynamicResource ErrorBrush}"
                                                   FontSize="13"
                                                   FontWeight="Medium"/>
                                        <TextBlock Text="从本机移除程序、配置与相关文件"
                                                   Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Command="{Binding UninstallLauncherCommand}"
                                            Content="卸载"
                                            Style="{StaticResource DangerActionButton}"
                                            VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
