<Window x:Class="YCPLauncher.Views.MessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="提示" Height="220" Width="420"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" ResizeMode="NoResize" Topmost="True">
    <Border CornerRadius="12" Background="{DynamicResource CardBgBrush}"
            BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="TxtTitle" Text="提示" Foreground="{StaticResource TextPrimaryBrush}" FontSize="18" FontWeight="Bold" Grid.Row="0"/>
            <TextBlock x:Name="TxtMessage" Text="消息内容" Foreground="{StaticResource TextMutedBrush}" FontSize="14" Margin="0,15,0,0" Grid.Row="1" TextWrapping="Wrap"/>

            <Button x:Name="BtnOk" Content="确定" Grid.Row="2" Style="{StaticResource OrangeButton}" Height="36" Width="100" HorizontalAlignment="Right" Click="BtnOk_Click" Cursor="Hand"/>
        </Grid>
    </Border>
</Window>
