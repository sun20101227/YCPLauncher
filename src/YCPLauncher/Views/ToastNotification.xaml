<UserControl x:Class="YCPLauncher.Views.ToastNotification"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Center"
             VerticalAlignment="Bottom"
             IsHitTestVisible="False">
    <Border x:Name="ToastBorder"
            Background="{DynamicResource CardBgBrush}"
            BorderBrush="{DynamicResource AccentBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16,10"
            Opacity="0">
        <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="ToastIcon" Text="✓" Foreground="{DynamicResource AccentBrush}"
                       FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock x:Name="ToastText" Foreground="{DynamicResource TextPrimaryBrush}"
                       FontSize="13" VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>
