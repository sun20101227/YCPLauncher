<UserControl x:Class="YCPLauncher.Views.LiveStreamView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1080"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded">

    <Grid x:Name="StreamShell" Margin="30,22,30,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <StackPanel>
                <TextBlock Text="赛事直播" FontSize="24" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="低延迟赛事画面" FontSize="13" Margin="0,5,0,0"
                           Foreground="{DynamicResource TextMutedBrush}"/>
            </StackPanel>
            <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                    Background="{DynamicResource CardBgBrush}"
                    BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1"
                    CornerRadius="12" Padding="12,7">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="7" Height="7" Fill="#EF4444" Margin="0,0,7,0"
                             VerticalAlignment="Center"/>
                    <TextBlock Text="LIVE" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" CornerRadius="18"
                Background="{DynamicResource MediaSurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1"
                ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="58"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="#FF000000">
                    <!--
                        LibVLCSharp.WPF renders through a native child window. Overlay content must
                        be hosted by VideoView itself to avoid WPF airspace repaint/flicker issues.
                    -->
                    <vlc:VideoView x:Name="VideoPlayer"
                                   Background="#FF000000"
                                   HorizontalContentAlignment="Stretch"
                                   VerticalContentAlignment="Stretch">
                        <Grid Background="Transparent">
                            <Border x:Name="LoadingOverlay"
                                    Background="#F0000000"
                                    Visibility="Visible">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border Width="48" Height="48" CornerRadius="24"
                                            Background="#33202020"
                                            BorderBrush="#44FFFFFF"
                                            BorderThickness="1"
                                            Margin="0,0,0,18">
                                        <TextBlock Text="&#xE714;"
                                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   FontSize="18" Foreground="{DynamicResource AccentBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="正在建立直播连接" FontSize="17" FontWeight="SemiBold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"/>
                                    <ProgressBar IsIndeterminate="True" Width="220" Height="3"
                                                 Margin="0,18,0,0" BorderThickness="0"
                                                 Foreground="{DynamicResource AccentBrush}"
                                                 Background="#33FFFFFF"/>
                                    <TextBlock x:Name="TimeoutHint" FontSize="12" Margin="0,12,0,0"
                                               Foreground="#B3FFFFFF"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="FailedOverlay"
                                    Background="#F0000000"
                                    Visibility="Collapsed">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE783;"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="30" Foreground="#99FFFFFF"
                                               HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                    <TextBlock Text="直播暂时无法连接" FontSize="20" FontWeight="SemiBold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="请检查直播源状态，或稍后重新连接"
                                               FontSize="13" Margin="0,7,0,22"
                                               Foreground="#B3FFFFFF"
                                               HorizontalAlignment="Center"/>
                                    <Button x:Name="BtnRetry" Content="重新连接"
                                            Width="132" Height="38"
                                            Style="{StaticResource OrangeButton}"
                                            Click="BtnRetry_Click"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </vlc:VideoView>
                </Grid>

                <Border Grid.Row="1" Background="{DynamicResource MediaControlsBrush}"
                        BorderBrush="{DynamicResource BorderBrush2}"
                        BorderThickness="0,1,0,0">
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="BtnPlayPause" Grid.Column="0"
                                Width="36" Height="36" Margin="0,0,8,0"
                                IsEnabled="False"
                                Style="{StaticResource IconButton}"
                                Click="BtnPlayPause_Click" ToolTip="播放或暂停">
                            <TextBlock x:Name="IconPlayPause" Text="&#xE769;"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="15"/>
                        </Button>

                        <Button x:Name="BtnRefresh" Grid.Column="1"
                                Width="36" Height="36"
                                IsEnabled="False"
                                Style="{StaticResource IconButton}"
                                Click="BtnRefresh_Click" ToolTip="重新连接">
                            <TextBlock Text="&#xE72C;"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="14"/>
                        </Button>

                        <Rectangle Grid.Column="2" Width="1" Height="20"
                                   Fill="{DynamicResource BorderBrush2}" Margin="14,0"/>

                        <StackPanel Grid.Column="3" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="&#xE767;"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="14" Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Slider x:Name="SldVolume" Minimum="0" Maximum="100" Value="100"
                                    Width="120" VerticalAlignment="Center"
                                    ValueChanged="SldVolume_ValueChanged"/>
                        </StackPanel>

                        <TextBlock Grid.Column="4" Text="YCP LIVE"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
